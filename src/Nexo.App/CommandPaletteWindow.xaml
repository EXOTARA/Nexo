<Window x:Class="Nexo.App.CommandPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Comandos de Kohana"
        Width="720"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        PreviewKeyDown="Window_PreviewKeyDown"
        Deactivated="Window_Deactivated"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <Style x:Key="PaletteIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface"
                                        Property="Background"
                                        Value="{DynamicResource BrushSurfaceRaised}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource BrushTextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Surface"
                                        Property="BorderBrush"
                                        Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.68" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuggestionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="11,9" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemSurface"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="15">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemSurface"
                                        Property="Background"
                                        Value="{DynamicResource BrushSurfaceHover}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemSurface"
                                        Property="Background"
                                        Value="{DynamicResource BrushAccentSoft}" />
                                <Setter TargetName="ItemSurface"
                                        Property="BorderBrush"
                                        Value="{DynamicResource BrushAccentBorder}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MotionChipStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceRaised}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChipSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipSurface" Property="Opacity" Value="0.84" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource BrushTextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ChipSurface"
                                        Property="BorderBrush"
                                        Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChipSurface" Property="Opacity" Value="0.64" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Margin="24"
            Padding="12"
            BorderThickness="1"
            CornerRadius="28"
            Opacity="0"
            SnapsToDevicePixels="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FD111620" Offset="0" />
                <GradientStop Color="#FB151B27" Offset="0.64" />
                <GradientStop Color="#FD1B1826" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#70FFFFFF" Offset="0" />
                <GradientStop Color="#1FFFFFFF" Offset="0.42" />
                <GradientStop Color="#4A8B6CFF" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="34"
                              ShadowDepth="10"
                              Opacity="0.46"
                              Color="#000000" />
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="PaletteTranslate" Y="-8" />
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="11,9"
                    Background="#B20D121B"
                    BorderBrush="#2DFFFFFF"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="46"
                            Height="46"
                            Margin="0,0,12,0"
                            VerticalAlignment="Top"
                            Background="{DynamicResource BrushAccentSoft}"
                            BorderBrush="{DynamicResource BrushAccentBorder}"
                            BorderThickness="1"
                            CornerRadius="15">
                        <TextBlock Text="✦"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource BrushAccent}"
                                   FontSize="19"
                                   FontWeight="SemiBold" />
                    </Border>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <TextBox x:Name="PromptTextBox"
                                 MinHeight="48"
                                 MaxHeight="104"
                                 Padding="1,8"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource BrushTextPrimary}"
                                 CaretBrush="{DynamicResource BrushAccent}"
                                 FontSize="19"
                                 FontWeight="Normal"
                                 TextChanged="PromptTextBox_TextChanged"
                                 SelectionBrush="{DynamicResource BrushAccentSoft}" />
                        <TextBlock x:Name="PlaceholderText"
                                   Text="Escribe una acción o pregunta"
                                   Margin="2,11,0,0"
                                   VerticalAlignment="Top"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   FontSize="19"
                                   IsHitTestVisible="False" />
                    </Grid>

                    <Border Grid.Column="2"
                            Margin="9,0,4,0"
                            Padding="9,6"
                            VerticalAlignment="Top"
                            Background="{DynamicResource BrushSurfaceRaised}"
                            CornerRadius="9">
                        <TextBlock Text="Esc"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   FontSize="11" />
                    </Border>

                    <Button Grid.Column="3"
                            x:Name="CustomizeButton"
                            Margin="4,0,0,0"
                            VerticalAlignment="Top"
                            Style="{StaticResource PaletteIconButtonStyle}"
                            Content="❈"
                            FontFamily="Segoe UI Symbol"
                            FontSize="17"
                            ToolTip="Movimiento y apariencia"
                            Click="CustomizeButton_Click" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    x:Name="ExpandedSurface"
                    Margin="0,10,0,0"
                    Padding="7"
                    Background="#B20F141E"
                    BorderBrush="#2CFFFFFF"
                    BorderThickness="1"
                    CornerRadius="20"
                    Visibility="Collapsed"
                    Opacity="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ListBox x:Name="SuggestionsList"
                             MaxHeight="318"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource SuggestionItemStyle}"
                             PreviewMouseLeftButtonDown="SuggestionsList_PreviewMouseLeftButtonDown"
                             MouseDoubleClick="SuggestionsList_MouseDoubleClick"
                             SelectionChanged="SuggestionsList_SelectionChanged"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="38"
                                            Height="38"
                                            Background="#66222938"
                                            BorderBrush="#20FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <TextBlock Text="{Binding Glyph}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource BrushAccent}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold" />
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="12,0,11,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Margin="0,3,0,0"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontSize="11.5"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Padding="9,5"
                                            VerticalAlignment="Center"
                                            Background="#72222938"
                                            CornerRadius="9"
                                            Visibility="{Binding ShortcutVisibility}">
                                        <TextBlock Text="{Binding ShortcutHint}"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontSize="11" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="1" Margin="12,9,12,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="InputModeDot"
                                         Width="6"
                                         Height="6"
                                         Margin="0,0,7,0"
                                         VerticalAlignment="Center"
                                         Fill="{DynamicResource BrushTextTertiary}" />
                                <TextBlock x:Name="InputModeText"
                                           Text="Escribe para buscar o preguntar"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           FontSize="11.5" />
                            </StackPanel>
                            <TextBlock Margin="0,5,0,0"
                                       Text="↑↓ elegir   ·   Tab completar   ·   Enter ejecutar o enviar   ·   Shift + Enter nueva línea"
                                       Foreground="{DynamicResource BrushTextTertiary}"
                                       FontSize="10.5" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="TimingText"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="10.5" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="Ctrl + Enter fuerza consulta"
                                       Foreground="{DynamicResource BrushTextTertiary}"
                                       FontSize="10.5" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    x:Name="CustomizationSurface"
                    Margin="0,10,0,0"
                    Padding="14"
                    Background="#E0181E29"
                    BorderBrush="#34FFFFFF"
                    BorderThickness="1"
                    CornerRadius="19"
                    Visibility="Collapsed"
                    Opacity="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Movimiento"
                                       FontWeight="SemiBold"
                                       FontSize="14" />
                            <TextBlock Text="Sutil por defecto; cambia la sensación sin recargar Kohana."
                                       Margin="0,3,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                        <CheckBox Grid.Column="1"
                                  x:Name="ReduceMotionCheckBox"
                                  Content="Reducir movimiento"
                                  VerticalAlignment="Center"
                                  Checked="ReduceMotionCheckBox_Changed"
                                  Unchecked="ReduceMotionCheckBox_Changed" />
                    </Grid>

                    <WrapPanel Grid.Row="1" Margin="0,13,0,0">
                        <Button x:Name="FluidMotionButton"
                                Tag="Fluid"
                                Style="{StaticResource MotionChipStyle}"
                                Content="Fluido"
                                Click="MotionPresetButton_Click" />
                        <Button x:Name="SnappyMotionButton"
                                Tag="Snappy"
                                Style="{StaticResource MotionChipStyle}"
                                Content="Rápido"
                                Click="MotionPresetButton_Click" />
                        <Button x:Name="CalmMotionButton"
                                Tag="Calm"
                                Style="{StaticResource MotionChipStyle}"
                                Content="Calmo"
                                Click="MotionPresetButton_Click" />
                        <Button x:Name="NoMotionButton"
                                Tag="None"
                                Style="{StaticResource MotionChipStyle}"
                                Content="Sin movimiento"
                                Click="MotionPresetButton_Click" />
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
