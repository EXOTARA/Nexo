<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Kohana Design System — Agregador de fundación (0.1).

        Punto único de entrada del tema. El orden importa: Colors define los Color*/Brush* base;
        Brushes añade alias semánticos que referencian esos Color*; Brand y Controls consumen los
        brushes. Typography, Spacing y Motion son independientes. App.xaml fusiona solo este
        archivo.
    -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml" />
        <ResourceDictionary Source="Typography.xaml" />
        <ResourceDictionary Source="Spacing.xaml" />
        <ResourceDictionary Source="Motion.xaml" />
        <ResourceDictionary Source="Brushes.xaml" />
        <ResourceDictionary Source="Brand.xaml" />
        <ResourceDictionary Source="Controls.xaml" />
    </ResourceDictionary.MergedDictionaries>
</ResourceDictionary>
