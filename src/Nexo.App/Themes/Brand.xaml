<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Responsive vector mark based on the Figma Sakura Premium direction. -->
    <Geometry x:Key="KohanaPetalGeometry">M12,12 C9.3,9.6 8.6,6.2 12,3.8 C15.4,6.2 14.7,9.6 12,12 Z</Geometry>

    <Style x:Key="KohanaFlowerMarkStyle" TargetType="ContentControl">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Foreground" Value="{DynamicResource BrushAccent}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Viewbox Stretch="Uniform">
                        <Canvas Width="24" Height="24">
                            <Path Data="{StaticResource KohanaPetalGeometry}"
                                  Fill="{TemplateBinding Foreground}"
                                  Opacity="0.12"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.25"
                                  StrokeLineJoin="Round" />
                            <Path Data="{StaticResource KohanaPetalGeometry}"
                                  Fill="{TemplateBinding Foreground}"
                                  Opacity="0.12"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.25"
                                  StrokeLineJoin="Round">
                                <Path.RenderTransform><RotateTransform Angle="72" CenterX="12" CenterY="12" /></Path.RenderTransform>
                            </Path>
                            <Path Data="{StaticResource KohanaPetalGeometry}"
                                  Fill="{TemplateBinding Foreground}"
                                  Opacity="0.12"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.25"
                                  StrokeLineJoin="Round">
                                <Path.RenderTransform><RotateTransform Angle="144" CenterX="12" CenterY="12" /></Path.RenderTransform>
                            </Path>
                            <Path Data="{StaticResource KohanaPetalGeometry}"
                                  Fill="{TemplateBinding Foreground}"
                                  Opacity="0.12"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.25"
                                  StrokeLineJoin="Round">
                                <Path.RenderTransform><RotateTransform Angle="216" CenterX="12" CenterY="12" /></Path.RenderTransform>
                            </Path>
                            <Path Data="{StaticResource KohanaPetalGeometry}"
                                  Fill="{TemplateBinding Foreground}"
                                  Opacity="0.12"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.25"
                                  StrokeLineJoin="Round">
                                <Path.RenderTransform><RotateTransform Angle="288" CenterX="12" CenterY="12" /></Path.RenderTransform>
                            </Path>
                            <Ellipse Width="3.6" Height="3.6" Canvas.Left="10.2" Canvas.Top="10.2"
                                     Fill="{DynamicResource BrushCoolBlue}" />
                        </Canvas>
                    </Viewbox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

