<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ColorBackground">#11131A</Color>
    <Color x:Key="ColorSurface">#1A1D26</Color>
    <Color x:Key="ColorSurfaceRaised">#222633</Color>
    <Color x:Key="ColorInput">#151821</Color>
    <Color x:Key="ColorBorder">#313646</Color>
    <Color x:Key="ColorTextPrimary">#F6F7FB</Color>
    <Color x:Key="ColorTextSecondary">#A9B0C3</Color>
    <Color x:Key="ColorAccent">#8B6CFF</Color>
    <Color x:Key="ColorAccentSoft">#2D2748</Color>
    <Color x:Key="ColorSuccess">#4CD787</Color>
    <Color x:Key="ColorWarning">#F4C95D</Color>

    <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorBackground}" />
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BrushSurfaceRaised" Color="{StaticResource ColorSurfaceRaised}" />
    <SolidColorBrush x:Key="BrushInput" Color="{StaticResource ColorInput}" />
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="BrushAccentSoft" Color="{StaticResource ColorAccentSoft}" />
    <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColorWarning}" />
</ResourceDictionary>
