<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Sakura Premium: neutral graphite surfaces with restrained floral accents. -->
    <Color x:Key="ColorBackground">#0C0E14</Color>
    <Color x:Key="ColorSurface">#111528</Color>
    <Color x:Key="ColorSurfaceRaised">#151922</Color>
    <Color x:Key="ColorSurfaceHover">#202630</Color>
    <Color x:Key="ColorInput">#0F131B</Color>
    <Color x:Key="ColorBorder">#2A303A</Color>
    <Color x:Key="ColorTextPrimary">#DFE1EA</Color>
    <Color x:Key="ColorTextSecondary">#AAAAB4</Color>
    <Color x:Key="ColorTextTertiary">#747986</Color>
    <Color x:Key="ColorAccent">#C4889A</Color>
    <Color x:Key="ColorAccentSoft">#2C2027</Color>
    <Color x:Key="ColorAccentBorder">#80C4889A</Color>
    <Color x:Key="ColorCoolBlue">#6B9CC8</Color>
    <Color x:Key="ColorCoolBlueSoft">#1C2937</Color>
    <Color x:Key="ColorSuccess">#71CFA8</Color>
    <Color x:Key="ColorWarning">#DDBE72</Color>
    <Color x:Key="ColorDanger">#DF7E8A</Color>

    <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorBackground}" />
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BrushSurfaceRaised" Color="{StaticResource ColorSurfaceRaised}" />
    <SolidColorBrush x:Key="BrushSurfaceHover" Color="{StaticResource ColorSurfaceHover}" />
    <SolidColorBrush x:Key="BrushInput" Color="{StaticResource ColorInput}" />
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="BrushTextTertiary" Color="{StaticResource ColorTextTertiary}" />
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}" />
    <SolidColorBrush x:Key="BrushAccentSoft" Color="{StaticResource ColorAccentSoft}" />
    <SolidColorBrush x:Key="BrushAccentBorder" Color="{StaticResource ColorAccentBorder}" />
    <SolidColorBrush x:Key="BrushCoolBlue" Color="{StaticResource ColorCoolBlue}" />
    <SolidColorBrush x:Key="BrushCoolBlueSoft" Color="{StaticResource ColorCoolBlueSoft}" />
    <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource ColorWarning}" />
    <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="BrushSakuraGlow" Color="#E4BBC7" />
</ResourceDictionary>
