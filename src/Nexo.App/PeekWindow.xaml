<Window x:Class="Nexo.App.PeekWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nexo Peek"
        Width="420"
        Height="132"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        WindowStartupLocation="Manual">
    <Border x:Name="PeekBorder"
            Margin="10"
            Background="{DynamicResource BrushBackground}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="17"
            Padding="14"
            Opacity="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="6"
                              Opacity="0.38"
                              Color="#000000" />
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="PeekTranslate" X="24" />
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <UniformGrid x:Name="PeekMetricsGrid" Columns="3">
                <StackPanel x:Name="CpuMetricPanel" Margin="0,0,12,0">
                    <TextBlock Text="CPU" Style="{StaticResource MutedTextStyle}" />
                    <TextBlock x:Name="CpuValueText" Text="—" FontSize="20" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel x:Name="MemoryMetricPanel" Margin="0,0,12,0">
                    <TextBlock Text="RAM" Style="{StaticResource MutedTextStyle}" />
                    <TextBlock x:Name="MemoryValueText" Text="—" FontSize="20" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel x:Name="GpuMetricPanel" Margin="0,0,12,0">
                    <TextBlock Text="GPU" Style="{StaticResource MutedTextStyle}" />
                    <TextBlock x:Name="GpuValueText" Text="—" FontSize="20" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel x:Name="DiskMetricPanel">
                    <TextBlock Text="DISCO" Style="{StaticResource MutedTextStyle}" />
                    <TextBlock x:Name="DiskValueText" Text="—" FontSize="20" FontWeight="SemiBold" />
                </StackPanel>
            </UniformGrid>

            <Grid x:Name="TopProcessPanel" Grid.Row="1" Margin="0,11,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse Width="7" Height="7"
                         VerticalAlignment="Center"
                         Fill="{DynamicResource BrushAccent}" />
                <TextBlock x:Name="TopProcessNameText"
                           Grid.Column="1"
                           Margin="8,0,10,0"
                           Text="Leyendo procesos..."
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource BrushTextSecondary}" />
                <TextBlock x:Name="TopProcessMemoryText"
                           Grid.Column="2"
                           Foreground="{DynamicResource BrushTextSecondary}" />
            </Grid>
        </Grid>
    </Border>
</Window>
