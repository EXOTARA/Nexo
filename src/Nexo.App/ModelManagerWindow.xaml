<Window x:Class="Nexo.App.ModelManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modelos locales de Nexo"
        Width="640"
        Height="570"
        MinWidth="560"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushBackground}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Modelos locales" Style="{StaticResource SectionTitleStyle}" />
            <TextBlock Margin="0,5,0,0"
                       Text="Administra los modelos disponibles en Ollama. Las descargas permanecen en tu equipo."
                       TextWrapping="Wrap"
                       Style="{StaticResource MutedTextStyle}" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,16,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Text="Comprobando Ollama…"
                       TextWrapping="Wrap"
                       Style="{StaticResource MutedTextStyle}" />
            <Button Grid.Column="1"
                    Margin="12,0,0,0"
                    Content="Actualizar"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="RefreshButton_Click" />
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="8">
            <ListBox x:Name="ModelsListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     SelectionChanged="ModelsListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8" MinHeight="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <TextBlock Margin="0,3,0,0"
                                           Text="{Binding ModifiedAt, StringFormat='Actualizado: {0:g}'}"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding SizeDisplay}"
                                       Style="{StaticResource MutedTextStyle}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="3" Margin="0,14,0,0" Style="{StaticResource SubtleCardStyle}">
            <StackPanel>
                <TextBlock Text="Descargar otro modelo" FontWeight="SemiBold" />
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ModelNameTextBox"
                             Text="qwen3.5:4b"
                             Style="{StaticResource CompactTextBoxStyle}" />
                    <Button x:Name="InstallButton"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            Content="Descargar"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="InstallButton_Click" />
                </Grid>
                <ProgressBar x:Name="DownloadProgressBar"
                             Margin="0,10,0,0"
                             Height="8"
                             Minimum="0"
                             Maximum="100"
                             IsIndeterminate="False"
                             Visibility="Collapsed" />
                <TextBlock x:Name="DownloadStatusText"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           Style="{StaticResource MutedTextStyle}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="DeleteButton"
                    Content="Eliminar seleccionado"
                    IsEnabled="False"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="DeleteButton_Click" />
            <Button Grid.Column="2"
                    Margin="0,0,10,0"
                    Content="Cerrar"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CloseButton_Click" />
            <Button x:Name="UseButton"
                    Grid.Column="3"
                    Content="Usar seleccionado"
                    IsEnabled="False"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="UseButton_Click" />
        </Grid>
    </Grid>
</Window>
