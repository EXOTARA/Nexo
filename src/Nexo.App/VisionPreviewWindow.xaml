<Window x:Class="Nexo.App.VisionPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vista previa de Nexo Vision"
        Width="840"
        Height="720"
        MinWidth="620"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBackground}"
        Foreground="{StaticResource BrushTextPrimary}"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Revisa la captura antes de compartirla"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="SourceTitleText"
                           Margin="0,5,0,0"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource BrushTextSecondary}" />
            </StackPanel>

            <Button Grid.Column="1"
                    Margin="12,0,0,0"
                    Padding="12,7"
                    Content="Seleccionar área"
                    ToolTip="Arrastra sobre la vista previa para conservar solo una región"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="SelectAreaButton_Click" />
            <Button x:Name="ApplySelectionButton"
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    Padding="12,7"
                    Content="Aplicar recorte"
                    IsEnabled="False"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="ApplySelectionButton_Click" />
            <Button Grid.Column="3"
                    Margin="8,0,0,0"
                    Padding="12,7"
                    Content="Restablecer"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="ResetImageButton_Click" />
        </Grid>

        <Border Grid.Row="1"
                Margin="0,14,0,0"
                Padding="8"
                CornerRadius="14"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                Background="#080A0F">
            <Grid x:Name="PreviewSurface"
                  ClipToBounds="True">
                <Image x:Name="PreviewImage"
                       Stretch="Uniform"
                       SnapsToDevicePixels="True" />
                <Canvas x:Name="SelectionCanvas"
                        Background="Transparent"
                        Cursor="Cross"
                        IsHitTestVisible="False"
                        MouseLeftButtonDown="SelectionCanvas_MouseLeftButtonDown"
                        MouseMove="SelectionCanvas_MouseMove"
                        MouseLeftButtonUp="SelectionCanvas_MouseLeftButtonUp">
                    <Rectangle x:Name="SelectionRectangle"
                               Visibility="Collapsed"
                               Stroke="{StaticResource BrushAccent}"
                               StrokeThickness="2"
                               Fill="#228B6CFF" />
                </Canvas>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="12"
                CornerRadius="12"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                Background="{StaticResource BrushSurfaceRaised}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Texto detectado localmente"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="OcrStatusText"
                                   Margin="0,3,0,0"
                                   Text="Preparando OCR…"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Padding="10,6"
                            Content="Copiar texto"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CopyOcrButton_Click" />
                </Grid>

                <TextBox x:Name="OcrTextBox"
                         Grid.Row="1"
                         Margin="0,10,0,0"
                         Height="110"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Style="{StaticResource CompactTextBoxStyle}" />

                <Border x:Name="PrivacyWarningPanel"
                        Grid.Row="2"
                        Margin="0,10,0,0"
                        Padding="10"
                        Visibility="Collapsed"
                        CornerRadius="9"
                        Background="#28C9922E"
                        BorderBrush="{StaticResource BrushWarning}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="PrivacyWarningText"
                                   TextWrapping="Wrap"
                                   FontWeight="SemiBold" />
                        <CheckBox x:Name="PrivacyReviewedCheckBox"
                                  Margin="0,8,0,0"
                                  Content="Revisé la captura y deseo usarla"
                                  Checked="PrivacyReviewedCheckBox_Changed"
                                  Unchecked="PrivacyReviewedCheckBox_Changed" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <CheckBox x:Name="KeepCaptureCheckBox"
                          Content="Mantener esta captura para preguntas de seguimiento" />
                <TextBlock Margin="0,5,0,0"
                           Text="Por defecto se elimina después de la siguiente respuesta. Nunca se guarda en el historial."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource BrushTextSecondary}"
                           FontSize="11" />
            </StackPanel>

            <Button Grid.Column="1"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="Descartar"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="DiscardButton_Click" />
            <Button x:Name="UseButton"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    Padding="14,8"
                    Content="Usar captura"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="UseButton_Click" />
        </Grid>
    </Grid>
</Window>
