<UserControl x:Class="Nexo.App.Views.AudioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Audio" Style="{StaticResource SectionTitleStyle}" />
            <TextBlock Margin="0,4,0,0"
                       Text="El mezclador real se conectará sobre esta vista."
                       Style="{StaticResource MutedTextStyle}" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,18,0,12" Style="{StaticResource SubtleCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Volumen principal" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="50%" Foreground="{DynamicResource BrushTextSecondary}" />
                <Slider Grid.Row="1" Grid.ColumnSpan="2"
                        Margin="0,10,0,0"
                        Minimum="0" Maximum="100" Value="50"
                        IsEnabled="False"
                        Style="{StaticResource NexoSliderStyle}" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Padding="10,5" Background="{DynamicResource BrushAccentSoft}" CornerRadius="9">
                <TextBlock Text="CONEXIÓN PENDIENTE"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           FontSize="10"
                           FontWeight="SemiBold" />
            </Border>
            <TextBlock Margin="0,12,0,0"
                       Text="Aquí aparecerán Spotify, Discord, el navegador y las demás sesiones activas."
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="290"
                       Style="{StaticResource MutedTextStyle}" />
        </StackPanel>
    </Grid>
</UserControl>
