<UserControl x:Class="Nexo.App.Views.AudioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="AudioView_Loaded"
             Unloaded="AudioView_Unloaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Audio" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock x:Name="DeviceNameText"
                           Margin="0,4,0,0"
                           Text="Buscando el dispositivo de salida…"
                           TextTrimming="CharacterEllipsis"
                           Style="{StaticResource MutedTextStyle}" />
            </StackPanel>

            <Button Grid.Column="1"
                    Width="34"
                    Height="34"
                    Content="↻"
                    ToolTip="Actualizar sesiones"
                    Click="RefreshButton_Click"
                    Style="{StaticResource IconButtonStyle}" />
        </Grid>

        <Border Grid.Row="1"
                Margin="0,18,0,14"
                Style="{StaticResource SubtleCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Volumen general" FontWeight="SemiBold" />
                <TextBlock x:Name="MasterVolumeText"
                           Grid.Column="1"
                           Margin="12,0"
                           VerticalAlignment="Center"
                           Text="—"
                           Foreground="{DynamicResource BrushTextSecondary}" />
                <Button x:Name="MasterMuteButton"
                        Grid.Column="2"
                        MinWidth="64"
                        Padding="9,5"
                        Content="Silenciar"
                        Click="MasterMuteButton_Click"
                        Style="{StaticResource SecondaryButtonStyle}" />

                <Slider x:Name="MasterVolumeSlider"
                        Grid.Row="1"
                        Grid.ColumnSpan="3"
                        Margin="0,12,0,0"
                        Minimum="0"
                        Maximum="100"
                        ValueChanged="MasterVolumeSlider_ValueChanged"
                        PreviewMouseLeftButtonUp="MasterVolumeSlider_MouseUp"
                        PreviewKeyUp="MasterVolumeSlider_KeyUp"
                        Style="{StaticResource NexoSliderStyle}" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="2,0,2,8">
            <TextBlock Text="Aplicaciones" FontWeight="SemiBold" />
            <TextBlock x:Name="SessionCountText"
                       HorizontalAlignment="Right"
                       Text="0 sesiones"
                       Style="{StaticResource MutedTextStyle}" />
        </Grid>

        <Grid Grid.Row="3">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="SessionsPanel" />
            </ScrollViewer>

            <StackPanel x:Name="EmptyStatePanel"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <Border Padding="10,5"
                        Background="{DynamicResource BrushAccentSoft}"
                        CornerRadius="9">
                    <TextBlock x:Name="EmptyStateTitle"
                               Text="SIN SESIONES ACTIVAS"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="11.5"
                               FontWeight="SemiBold" />
                </Border>
                <TextBlock x:Name="EmptyStateDetail"
                           Margin="0,12,0,0"
                           MaxWidth="290"
                           Text="Reproduce audio en una aplicación y pulsa actualizar."
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Style="{StaticResource MutedTextStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
