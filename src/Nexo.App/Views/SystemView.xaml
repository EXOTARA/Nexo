<UserControl x:Class="Nexo.App.Views.SystemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <StackPanel>
                <TextBlock Text="Sistema y Runtime" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Margin="0,4,0,0"
                           Text="Estado del equipo y de los servicios que Kohana mantiene en segundo plano."
                           TextWrapping="Wrap"
                           Style="{StaticResource MutedTextStyle}" />
            </StackPanel>

            <UniformGrid Columns="2" Rows="2" Margin="-4,14,-4,8">
                <Border Style="{StaticResource SubtleCardStyle}" Margin="4">
                    <StackPanel>
                        <TextBlock Text="CPU" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock x:Name="CpuValueText" Text="—" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SubtleCardStyle}" Margin="4">
                    <StackPanel>
                        <TextBlock Text="RAM" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock x:Name="MemoryValueText" Text="—" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SubtleCardStyle}" Margin="4">
                    <StackPanel>
                        <TextBlock Text="GPU" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock x:Name="GpuValueText" Text="—" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock x:Name="GpuMemoryText" Margin="0,2,0,0" Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SubtleCardStyle}" Margin="4">
                    <StackPanel>
                        <TextBlock Text="DISCO USADO" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock x:Name="DiskValueText" Text="—" FontSize="22" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource SubtleCardStyle}" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Mayor uso de memoria" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock x:Name="TopProcessNameText"
                                   Margin="0,5,0,0"
                                   Text="Esperando datos..."
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <TextBlock x:Name="TopProcessMemoryText"
                               Grid.Column="1"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="14" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SubtleCardStyle}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Kohana Runtime" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Margin="0,3,0,0"
                                       Text="Servicios locales, privacidad y rendimiento en una sola vista."
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Reiniciar voz"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="RestartVoiceButton_Click" />
                            <Button Content="Diagnóstico"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="DiagnosticsButton_Click" />
                        </StackPanel>
                    </Grid>

                    <UniformGrid Columns="2" Margin="-4,12,-4,0">
                        <Border Margin="4" Padding="11" Background="{DynamicResource BrushSurfaceRaised}" CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="VOZ" Style="{StaticResource MutedTextStyle}" />
                                <TextBlock x:Name="RuntimeVoiceText" Margin="0,4,0,0" Text="Comprobando…" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Margin="4" Padding="11" Background="{DynamicResource BrushSurfaceRaised}" CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="IA" Style="{StaticResource MutedTextStyle}" />
                                <TextBlock x:Name="RuntimeAiText" Margin="0,4,0,0" Text="Desactivada" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                        <Border Margin="4" Padding="11" Background="{DynamicResource BrushSurfaceRaised}" CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="VISION" Style="{StaticResource MutedTextStyle}" />
                                <TextBlock x:Name="RuntimeVisionText" Margin="0,4,0,0" Text="Activa bajo demanda" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Margin="4" Padding="11" Background="{DynamicResource BrushSurfaceRaised}" CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="RENDIMIENTO" Style="{StaticResource MutedTextStyle}" />
                                <TextBlock x:Name="RuntimeModeText" Margin="0,4,0,0" Text="Normal" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <TextBlock x:Name="RuntimeDetailText"
                               Margin="4,9,4,0"
                               Text="Kohana está lista."
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="HealthText"
                               Text="Leyendo el equipo..."
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushSuccess}" />
                    <TextBlock Margin="0,4,0,0"
                               Text="Alt + Shift + A abre la vista Peek sin mostrar toda la barra."
                               TextWrapping="Wrap"
                               Style="{StaticResource MutedTextStyle}" />
                </StackPanel>
                <TextBlock x:Name="UpdatedAtText"
                           Grid.Column="1"
                           Margin="12,0,0,0"
                           VerticalAlignment="Bottom"
                           Style="{StaticResource MutedTextStyle}" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
