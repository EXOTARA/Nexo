<UserControl x:Class="Nexo.App.Views.CaptureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="CapturePrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource BrushAccent}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                CornerRadius="15">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.68" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Captura" Style="{StaticResource SectionTitleStyle}" />
            <TextBlock Margin="0,4,0,0"
                       Text="Comparte solo la ventana o pantalla que elijas."
                       Style="{StaticResource MutedTextStyle}" />
        </StackPanel>

        <Button Grid.Row="1"
                Margin="0,22,0,0"
                Padding="18,16"
                HorizontalContentAlignment="Stretch"
                Style="{StaticResource CapturePrimaryButtonStyle}"
                Click="CaptureButton_Click">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="42"
                        Height="42"
                        Background="#26FFFFFF"
                        CornerRadius="13">
                    <TextBlock Text="▣"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="17" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="13,0,12,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Analizar una ventana"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,3,0,0"
                               Text="Elige una ventana o monitor y confirma antes de compartir."
                               Foreground="#D8FFFFFF"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Text="→"
                           VerticalAlignment="Center"
                           FontSize="18" />
            </Grid>
        </Button>

        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <TextBlock Text="Más formas de capturar"
                       FontSize="12"
                       FontWeight="SemiBold" />

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Margin="0,0,6,0"
                        Padding="13"
                        Background="{DynamicResource BrushSurfaceRaised}"
                        CornerRadius="13"
                        Opacity="0.72">
                    <StackPanel>
                        <TextBlock Text="Región"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,3,0,0"
                                   Text="Recorte preciso"
                                   Style="{StaticResource MutedTextStyle}" />
                        <TextBlock Margin="0,9,0,0"
                                   Text="PRÓXIMAMENTE"
                                   Foreground="{DynamicResource BrushAccent}"
                                   FontSize="10.5"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="6,0,0,0"
                        Padding="13"
                        Background="{DynamicResource BrushSurfaceRaised}"
                        CornerRadius="13"
                        Opacity="0.72">
                    <StackPanel>
                        <TextBlock Text="Con retraso"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,3,0,0"
                                   Text="Tiempo para preparar la pantalla"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,9,0,0"
                                   Text="PRÓXIMAMENTE"
                                   Foreground="{DynamicResource BrushAccent}"
                                   FontSize="10.5"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>

        <Border Grid.Row="3"
                Margin="0,18,0,0"
                Padding="12,10"
                Background="#381A1D26"
                CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="✦"
                           Margin="0,0,8,0"
                           Foreground="{DynamicResource BrushAccent}" />
                <TextBlock Grid.Column="1"
                           Text="Nexo no captura nada hasta que confirmas la selección."
                           Foreground="{DynamicResource BrushTextSecondary}"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
