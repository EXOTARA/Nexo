<UserControl x:Class="Nexo.App.Views.AssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <Style x:Key="QuickPromptButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="13,10" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Chat con Kohana"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <StackPanel Margin="0,7,0,0" Orientation="Horizontal">
                    <Ellipse Width="7"
                             Height="7"
                             Margin="0,0,7,0"
                             VerticalAlignment="Center"
                             Fill="{DynamicResource BrushSuccess}" />
                    <TextBlock x:Name="AiProviderStatusText"
                               Text="IA desactivada · los comandos locales siguen disponibles"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="11.5" />
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1"
                    Margin="12,0,0,0"
                    Padding="11,8"
                    VerticalAlignment="Top"
                    ToolTip="Nueva conversación"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="ClearConversationButton_Click">
                <StackPanel Orientation="Horizontal">
                    <Path Width="15"
                          Height="15"
                          Margin="0,0,7,0"
                          Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="{StaticResource IconKohanaPlus}" />
                    <TextBlock Text="Nuevo" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="0,14,0,12">
            <Border x:Name="EmptyStatePanel"
                    Padding="24"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    Background="{DynamicResource BrushSurfaceRaised}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="22">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="58"
                            Height="58"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource BrushSurface}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="19">
                        <ContentControl Width="31"
                                        Height="31"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource BrushAccent}"
                                        Style="{StaticResource KohanaFlowerMarkStyle}" />
                    </Border>
                    <TextBlock Margin="0,17,0,0"
                               Text="¿Qué hacemos hoy?"
                               HorizontalAlignment="Center"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,7,0,14"
                               MaxWidth="430"
                               Text="Pide una acción, pregunta algo o comparte una ventana. Kohana ejecuta primero lo que puede resolver de forma local."
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="12.5"
                               LineHeight="19" />
                    <WrapPanel MaxWidth="470" HorizontalAlignment="Center">
                        <Button Tag="Abre PowerShell en mi carpeta de usuario"
                                Content="Abrir PowerShell"
                                Style="{StaticResource QuickPromptButtonStyle}"
                                Click="QuickPromptButton_Click" />
                        <Button Tag="¿Qué tengo pendiente hoy?"
                                Content="Ver mis pendientes"
                                Style="{StaticResource QuickPromptButtonStyle}"
                                Click="QuickPromptButton_Click" />
                        <Button Tag="Inicia una sesión de enfoque de 25 minutos"
                                Content="Empezar enfoque"
                                Style="{StaticResource QuickPromptButtonStyle}"
                                Click="QuickPromptButton_Click" />
                        <Button Tag="Mira la ventana activa y ayúdame con lo que aparece"
                                Content="Analizar una ventana"
                                Style="{StaticResource QuickPromptButtonStyle}"
                                Click="QuickPromptButton_Click" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <ScrollViewer x:Name="ConversationScroll"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ConversationPanel" />
            </ScrollViewer>
        </Grid>

        <Border x:Name="VisionAttachmentPanel"
                Grid.Row="2"
                Margin="0,0,0,11"
                Padding="9"
                Visibility="Collapsed"
                CornerRadius="15"
                Background="{DynamicResource BrushSurfaceRaised}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="78" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="72"
                        Height="58"
                        CornerRadius="11"
                        ClipToBounds="True"
                        Background="{DynamicResource BrushBackground}">
                    <Image x:Name="VisionPreviewImage" Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="11,0,9,0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="VisionAttachmentTitleText"
                               Text="Contexto visual listo"
                               FontSize="13.5"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="VisionSourceTitleText"
                               Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource MutedTextStyle}" />
                    <TextBlock x:Name="VisionAttachmentHintText"
                               Margin="0,3,0,0"
                               Text="Se enviará solo con tu siguiente consulta."
                               Foreground="{DynamicResource BrushTextTertiary}"
                               FontSize="11" />
                </StackPanel>

                <Button Grid.Column="2"
                        Width="34"
                        Height="34"
                        Padding="0"
                        VerticalAlignment="Center"
                        Content="×"
                        ToolTip="Descartar captura"
                        Style="{StaticResource IconButtonStyle}"
                        Click="DiscardVisionButton_Click" />
            </Grid>
        </Border>

        <TextBlock x:Name="VoiceStatusText"
                   Grid.Row="3"
                   Margin="4,0,0,8"
                   Text="Preparando reconocimiento local…"
                   TextTrimming="CharacterEllipsis"
                   Foreground="{DynamicResource BrushTextSecondary}"
                   FontSize="11.5"
                   Visibility="Collapsed" />

        <Border Grid.Row="4"
                Padding="8"
                Background="{DynamicResource BrushInput}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="VisionButton"
                        Grid.Column="0"
                        Margin="0,0,7,0"
                        Width="42"
                        Height="42"
                        Padding="0"
                        VerticalAlignment="Center"
                        ToolTip="Mirar la ventana activa · Ctrl + Shift + Espacio"
                        Style="{StaticResource IconButtonStyle}"
                        Click="VisionButton_Click">
                    <Path Width="19"
                          Height="19"
                          Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.65"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="{StaticResource IconKohanaLook}" />
                </Button>

                <Grid Grid.Column="1">
                    <TextBlock x:Name="PromptHintText"
                               Margin="11,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               Text="Escribe una orden o pregunta…"
                               Foreground="{DynamicResource BrushTextTertiary}"
                               FontSize="14" />
                    <TextBox x:Name="PromptBox"
                             MinHeight="46"
                             MaxHeight="108"
                             Padding="10,7"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontSize="14"
                             Background="Transparent"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"
                             TextChanged="PromptBox_TextChanged"
                             PreviewKeyDown="PromptBox_PreviewKeyDown" />
                </Grid>

                <Button x:Name="MicButton"
                        Grid.Column="2"
                        Margin="7,0,0,0"
                        Width="42"
                        Height="42"
                        Padding="0"
                        VerticalAlignment="Center"
                        IsEnabled="False"
                        ToolTip="Pulsa para hablar · pulsa de nuevo para terminar"
                        Style="{StaticResource IconButtonStyle}"
                        Click="MicButton_Click">
                    <Path x:Name="MicGlyph"
                          Width="18"
                          Height="18"
                          Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.65"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="{StaticResource IconKohanaMic}" />
                </Button>

                <Button Grid.Column="3"
                        Margin="7,0,0,0"
                        Width="44"
                        Height="44"
                        Padding="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource PrimaryButtonStyle}"
                        ToolTip="Enviar"
                        Click="SendButton_Click">
                    <Path Width="18"
                          Height="18"
                          Stretch="Uniform"
                          Stroke="White"
                          StrokeThickness="1.7"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="{StaticResource IconKohanaSend}" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
