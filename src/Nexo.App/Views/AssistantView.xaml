<UserControl x:Class="Nexo.App.Views.AssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="¿Qué necesitas?" Style="{StaticResource SectionTitleStyle}" />
            <TextBlock Margin="0,4,0,0"
                       Text="Escribe una consulta o una orden local."
                       Style="{StaticResource MutedTextStyle}" />
        </StackPanel>

        <ScrollViewer x:Name="ConversationScroll"
                      Grid.Row="1"
                      Margin="0,16,0,14"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ConversationPanel">
                <Border Background="{DynamicResource BrushSurfaceRaised}"
                        CornerRadius="13"
                        Padding="12"
                        HorizontalAlignment="Left"
                        MaxWidth="310">
                    <TextBlock Text="Hola. La interfaz ya está separada en módulos. En los siguientes sprints conectaremos comandos, audio e IA."
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="PromptBox"
                     Height="74"
                     AcceptsReturn="True"
                     Style="{StaticResource PromptTextBoxStyle}"
                     PreviewKeyDown="PromptBox_PreviewKeyDown" />
            <Button Grid.Column="1"
                    Margin="10,0,0,0"
                    Width="74"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Enviar"
                    Click="SendButton_Click" />
        </Grid>
    </Grid>
</UserControl>
