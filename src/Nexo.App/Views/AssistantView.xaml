<UserControl x:Class="Nexo.App.Views.AssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <Geometry x:Key="IconLook">M2,10 C5,4.8 8,3 10,3 C12,3 15,4.8 18,10 C15,15.2 12,17 10,17 C8,17 5,15.2 2,10 Z M7,10 C7,11.7 8.3,13 10,13 C11.7,13 13,11.7 13,10 C13,8.3 11.7,7 10,7 C8.3,7 7,8.3 7,10 Z</Geometry>
        <Geometry x:Key="IconMic">M7,4 C7,1.8 8.3,1 10,1 C11.7,1 13,1.8 13,4 L13,10 C13,12.2 11.7,13 10,13 C8.3,13 7,12.2 7,10 Z M4,9 C4,13 6.7,16 10,16 C13.3,16 16,13 16,9 M10,16 L10,19 M7,19 L13,19</Geometry>
        <Geometry x:Key="IconSend">M3,10 L17,3 L13,17 L9.5,11.5 Z M9.5,11.5 L17,3</Geometry>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="¿Qué necesitas?"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,5,0,0"
                           Text="Ordena algo, pregunta o comparte lo que estás viendo."
                           Foreground="{DynamicResource BrushTextSecondary}"
                           FontSize="12.5"
                           LineHeight="18" />
                <Border Margin="0,9,0,0"
                        Padding="9,6"
                        HorizontalAlignment="Left"
                        Background="#66202735"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7"
                                 Height="7"
                                 Margin="0,0,7,0"
                                 VerticalAlignment="Center"
                                 Fill="{DynamicResource BrushSuccess}" />
                        <TextBlock x:Name="AiProviderStatusText"
                                   Text="IA desactivada · los comandos locales siguen disponibles"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   FontSize="11.5" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Button Grid.Column="1"
                    Margin="11,0,0,0"
                    Padding="0"
                    VerticalAlignment="Top"
                    Content="⌫"
                    FontSize="16"
                    ToolTip="Limpiar conversación"
                    Style="{StaticResource IconButtonStyle}"
                    Click="ClearConversationButton_Click" />
        </Grid>

        <ScrollViewer x:Name="ConversationScroll"
                      Grid.Row="1"
                      Margin="0,16,0,12"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ConversationPanel" />
        </ScrollViewer>

        <Border x:Name="VisionAttachmentPanel"
                Grid.Row="2"
                Margin="0,0,0,11"
                Padding="9"
                Visibility="Collapsed"
                CornerRadius="15"
                Background="#B01B2230"
                BorderBrush="#38FFFFFF"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="78" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="72"
                        Height="58"
                        CornerRadius="11"
                        ClipToBounds="True"
                        Background="#080A0F">
                    <Image x:Name="VisionPreviewImage"
                           Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="11,0,9,0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="VisionAttachmentTitleText"
                               Text="Contexto visual listo"
                               FontSize="13.5"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="VisionSourceTitleText"
                               Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource MutedTextStyle}" />
                    <TextBlock x:Name="VisionAttachmentHintText"
                               Margin="0,3,0,0"
                               Text="Se enviará solo con tu siguiente consulta."
                               Foreground="{DynamicResource BrushTextTertiary}"
                               FontSize="11" />
                </StackPanel>

                <Button Grid.Column="2"
                        Width="34"
                        Height="34"
                        Padding="0"
                        VerticalAlignment="Center"
                        Content="×"
                        ToolTip="Descartar captura"
                        Style="{StaticResource IconButtonStyle}"
                        Click="DiscardVisionButton_Click" />
            </Grid>
        </Border>

        <TextBlock x:Name="VoiceStatusText"
                   Grid.Row="3"
                   Margin="4,0,0,8"
                   Text="Preparando reconocimiento local…"
                   TextTrimming="CharacterEllipsis"
                   Foreground="{DynamicResource BrushTextSecondary}"
                   FontSize="11.5"
                   Visibility="Collapsed" />

        <Border Grid.Row="4"
                Padding="8"
                Background="#C00E141E"
                BorderBrush="#42FFFFFF"
                BorderThickness="1"
                CornerRadius="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="PromptBox"
                         MinHeight="46"
                         MaxHeight="108"
                         Padding="10,7"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontSize="14"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         PreviewKeyDown="PromptBox_PreviewKeyDown" />

                <Button x:Name="VisionButton"
                        Grid.Column="1"
                        Margin="7,0,0,0"
                        Width="42"
                        Height="42"
                        Padding="0"
                        VerticalAlignment="Center"
                        ToolTip="Mirar la ventana activa · Ctrl + Shift + Espacio"
                        Style="{StaticResource IconButtonStyle}"
                        Click="VisionButton_Click">
                    <Path Width="19"
                          Height="19"
                          Stretch="Uniform"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Data="{StaticResource IconLook}" />
                </Button>

                <Button x:Name="MicButton"
                        Grid.Column="2"
                        Margin="7,0,0,0"
                        Width="42"
                        Height="42"
                        Padding="0"
                        VerticalAlignment="Center"
                        IsEnabled="False"
                        ToolTip="Pulsa para hablar · pulsa de nuevo para terminar"
                        Style="{StaticResource IconButtonStyle}"
                        Click="MicButton_Click">
                    <Path x:Name="MicGlyph"
                          Width="18"
                          Height="18"
                          Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="{StaticResource IconMic}" />
                </Button>

                <Button Grid.Column="3"
                        Margin="7,0,0,0"
                        Width="44"
                        Height="44"
                        Padding="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource PrimaryButtonStyle}"
                        ToolTip="Enviar"
                        Click="SendButton_Click">
                    <Path Width="18"
                          Height="18"
                          Stretch="Uniform"
                          Stroke="White"
                          StrokeThickness="1.8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="{StaticResource IconSend}" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
