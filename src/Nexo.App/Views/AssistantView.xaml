<UserControl x:Class="Nexo.App.Views.AssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="¿Qué necesitas?" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Margin="0,4,0,0"
                           Text="Escribe una consulta o mantén Mic para hablar."
                           Style="{StaticResource MutedTextStyle}" />
            </StackPanel>

            <Button Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="10,6"
                    VerticalAlignment="Top"
                    Content="Limpiar"
                    ToolTip="Vaciar la conversación visible"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="ClearConversationButton_Click" />
        </Grid>

        <ScrollViewer x:Name="ConversationScroll"
                      Grid.Row="1"
                      Margin="0,16,0,10"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ConversationPanel" />
        </ScrollViewer>

        <TextBlock x:Name="VoiceStatusText"
                   Grid.Row="2"
                   Margin="2,0,0,8"
                   Text="El micrófono solo se activa mientras mantienes presionado Mic."
                   TextTrimming="CharacterEllipsis"
                   Style="{StaticResource MutedTextStyle}" />

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="PromptBox"
                     Height="74"
                     AcceptsReturn="True"
                     Style="{StaticResource PromptTextBoxStyle}"
                     PreviewKeyDown="PromptBox_PreviewKeyDown" />

            <Button x:Name="MicButton"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Width="58"
                    Content="Mic"
                    ToolTip="Mantén presionado para hablar"
                    Style="{StaticResource SecondaryButtonStyle}"
                    PreviewMouseLeftButtonDown="MicButton_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="MicButton_PreviewMouseLeftButtonUp"
                    LostMouseCapture="MicButton_LostMouseCapture"
                    PreviewKeyDown="MicButton_PreviewKeyDown"
                    PreviewKeyUp="MicButton_PreviewKeyUp" />

            <Button Grid.Column="2"
                    Margin="10,0,0,0"
                    Width="74"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Enviar"
                    Click="SendButton_Click" />
        </Grid>
    </Grid>
</UserControl>
