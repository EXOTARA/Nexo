<Window x:Class="Nexo.App.VisionTargetPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elegir qué verá Nexo"
        Width="520"
        Height="560"
        MinWidth="440"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBackground}"
        Foreground="{StaticResource BrushTextPrimary}"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="¿Qué quieres mostrarle a Nexo?"
                       FontSize="20"
                       FontWeight="SemiBold" />
            <TextBlock Margin="0,6,0,14"
                       Text="La captura se muestra antes de enviarse y no se guarda en el historial."
                       TextWrapping="Wrap"
                       Foreground="{StaticResource BrushTextSecondary}" />
        </StackPanel>

        <Border Grid.Row="1"
                Padding="8"
                CornerRadius="14"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                Background="{StaticResource BrushSurface}">
            <ListBox x:Name="TargetsList"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="{StaticResource BrushTextPrimary}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     MouseDoubleClick="TargetsList_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="28"
                                    Height="28"
                                    CornerRadius="8"
                                    Background="{StaticResource BrushAccentSoft}">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="◫"
                                           FontSize="14" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="{Binding Title}"
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,2,0,0"
                                           Text="{Binding Subtitle}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="12" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center"
                       Text="No se muestran gestores de contraseñas ni ventanas de seguridad."
                       TextWrapping="Wrap"
                       Foreground="{StaticResource BrushTextSecondary}"
                       FontSize="12" />
            <Button Grid.Column="1"
                    Margin="12,0,0,0"
                    Padding="14,8"
                    Content="Cancelar"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CancelButton_Click" />
            <Button Grid.Column="2"
                    Margin="10,0,0,0"
                    Padding="14,8"
                    Content="Capturar"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="CaptureButton_Click" />
        </Grid>
    </Grid>
</Window>
