<Window x:Class="Nexo.App.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagnóstico de Nexo"
        Width="660"
        Height="620"
        MinWidth="580"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BrushBackground}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Centro de diagnóstico" Style="{StaticResource SectionTitleStyle}" />
            <TextBlock Margin="0,5,0,0"
                       Text="Revisa los servicios principales sin copiar conversaciones, capturas ni claves."
                       TextWrapping="Wrap"
                       Style="{StaticResource MutedTextStyle}" />
        </StackPanel>

        <TextBlock x:Name="SummaryText"
                   Grid.Row="1"
                   Margin="0,15,0,10"
                   Text="Preparando diagnóstico…"
                   TextWrapping="Wrap"
                   Style="{StaticResource MutedTextStyle}" />

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="5" Padding="12" Style="{StaticResource SubtleCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="9"
                                            Height="9"
                                            Margin="0,5,10,0"
                                            VerticalAlignment="Top"
                                            Background="{Binding StatusBrush}"
                                            CornerRadius="5" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Text="{Binding Detail}"
                                                   TextWrapping="Wrap"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="Actualizar"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="RefreshButton_Click" />
            <Button Grid.Column="1"
                    Margin="9,0,0,0"
                    Content="Copiar"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CopyButton_Click" />
            <Button Grid.Column="2"
                    Margin="9,0,0,0"
                    Content="Abrir datos"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="OpenDataButton_Click" />
            <Button Grid.Column="3"
                    Margin="9,0,0,0"
                    HorizontalAlignment="Left"
                    Content="Limpiar temporales"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="ClearTemporaryButton_Click" />
            <Button Grid.Column="4"
                    Content="Cerrar"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="CloseButton_Click" />
        </Grid>
    </Grid>
</Window>
