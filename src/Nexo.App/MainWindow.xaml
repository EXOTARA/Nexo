<Window x:Class="Nexo.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kohana"
        Width="720"
        Height="790"
        MinWidth="680"
        MinHeight="680"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing"
        Closed="Window_Closed"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>

        <Style x:Key="SideRailIconStyle" TargetType="Path">
            <Setter Property="Width" Value="21" />
            <Setter Property="Height" Value="21" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            <Setter Property="StrokeThickness" Value="1.65" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
        </Style>

        <Style x:Key="FilledSideRailIconStyle"
               TargetType="Path"
               BasedOn="{StaticResource SideRailIconStyle}">
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        </Style>

        <Style x:Key="SideNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Width" Value="178" />
            <Setter Property="Height" Value="46" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="260" />
            <Setter Property="ToolTipService.ShowDuration" Value="3200" />
            <Setter Property="ToolTipService.Placement" Value="Right" />
        </Style>

        <Style x:Key="SideRailToggleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="178" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="{DynamicResource BrushSurfaceHover}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Surface" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderCommandButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceRaised}" />
            <Setter Property="BorderBrush" Value="#2EFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="{DynamicResource BrushSurfaceHover}" />
                                <Setter TargetName="Surface" Property="BorderBrush" Value="{DynamicResource BrushAccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Surface" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="ShellBorder"
            Margin="16"
            Background="{DynamicResource BrushBackground}"
            BorderThickness="1"
            CornerRadius="30"
            Opacity="0"
            SnapsToDevicePixels="True">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#70FFFFFF" Offset="0" />
                <GradientStop Color="#20FFFFFF" Offset="0.45" />
                <GradientStop Color="#35C4889A" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="38"
                              ShadowDepth="10"
                              Opacity="0.45"
                              Color="#000000" />
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="ShellTranslate" X="24" />
        </Border.RenderTransform>

        <Grid ClipToBounds="True">
            <Border CornerRadius="29">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#24111528" Offset="0" />
                        <GradientStop Color="#0D101820" Offset="0.52" />
                        <GradientStop Color="#24151922" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Ellipse Width="280"
                     Height="280"
                     Margin="-120,-140,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="#12C4889A"
                     IsHitTestVisible="False">
                <Ellipse.Effect>
                    <BlurEffect Radius="65" />
                </Ellipse.Effect>
            </Ellipse>

            <Ellipse Width="220"
                     Height="220"
                     Margin="0,0,-100,-120"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Fill="#1264D7A5"
                     IsHitTestVisible="False">
                <Ellipse.Effect>
                    <BlurEffect Radius="70" />
                </Ellipse.Effect>
            </Ellipse>

            <Grid Margin="13">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="SideRailBorder"
                        Grid.Column="0"
                        Width="68"
                        Margin="0"
                        Padding="7,10"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Background="#F2161C27"
                        BorderBrush="#38FFFFFF"
                        BorderThickness="1"
                        CornerRadius="22"
                        ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22"
                                          ShadowDepth="5"
                                          Opacity="0.28"
                                          Color="#000000" />
                    </Border.Effect>

                    <Grid Width="178" HorizontalAlignment="Left">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Button x:Name="SideRailToggleButton"
                                Style="{StaticResource SideRailToggleButtonStyle}"
                                ToolTip="Expandir o contraer navegación"
                                Click="SideRailToggleButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="42"
                                        Height="42"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource BrushSurfaceRaised}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <ContentControl Width="21"
                                                    Height="21"
                                                    Foreground="{DynamicResource BrushAccent}"
                                                    Style="{StaticResource KohanaFlowerMarkStyle}" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Kohana"
                                               FontSize="15"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Tu Windows, en flor"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource BrushTextTertiary}"
                                               FontSize="11.5" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <StackPanel Grid.Row="1"
                                    x:Name="NavigationGrid"
                                    Margin="0,14,0,8"
                                    VerticalAlignment="Top">
                            <Button x:Name="HomeNavButton"
                                    Tag="Home"
                                    ToolTip="Inicio"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconKohanaHome}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Inicio" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="AssistantNavButton"
                                    Tag="Assistant"
                                    ToolTip="Asistente"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconKohanaAssistant}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Chat" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="TasksNavButton"
                                    Tag="Tasks"
                                    ToolTip="Pendientes de hoy"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconKohanaTasks}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Hoy" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="FocusNavButton"
                                    Tag="Focus"
                                    ToolTip="Enfoque"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconKohanaFocus}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Enfoque" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="RoutinesNavButton"
                                    Tag="Routines"
                                    ToolTip="Rutinas"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconKohanaRoutines}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Rutinas" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="AudioNavButton"
                                    Tag="Audio"
                                    ToolTip="Audio"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconKohanaAudio}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Audio" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="CaptureNavButton"
                                    Tag="Capture"
                                    ToolTip="Captura"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconKohanaCapture}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Captura" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="SystemNavButton"
                                    Tag="System"
                                    ToolTip="Sistema"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconKohanaSystem}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Sistema" FontSize="14" />
                                </Grid>
                            </Button>
                        </StackPanel>

                        <Button Grid.Row="2"
                                x:Name="SettingsNavButton"
                                Tag="Settings"
                                ToolTip="Personalización y perfiles"
                                Click="SettingsButton_Click"
                                Style="{StaticResource SideNavButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconKohanaSettings}" />
                                <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Personalizar" FontSize="14" />
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="13,2,2,2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="5,4,5,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="WorkspaceTitleText"
                                           Text="Inicio"
                                           MaxWidth="360"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Border x:Name="WakeWordIndicator"
                                        Margin="11,1,0,0"
                                        Padding="8,3"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource BrushSurfaceRaised}"
                                        CornerRadius="9"
                                        Visibility="Collapsed"
                                        ToolTip="La activación por voz escucha únicamente la frase configurada.">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7"
                                                 Height="7"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{DynamicResource BrushSuccess}" />
                                        <TextBlock x:Name="WakeWordIndicatorText"
                                                   Text="Kohana atenta"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <Border x:Name="ResourceModeIndicator"
                                        Margin="8,1,0,0"
                                        Padding="8,3"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource BrushSurfaceRaised}"
                                        BorderBrush="#2AFFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="9"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="ResourceModeDot"
                                                 Width="7"
                                                 Height="7"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{DynamicResource BrushWarning}" />
                                        <TextBlock x:Name="ResourceModeText"
                                                   Text="Equipo ocupado"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <TextBlock x:Name="WorkspaceSubtitleText"
                                       Margin="0,5,0,0"
                                       Text="Tu espacio de acciones y contexto"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="11.5"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="9"
                                    Height="9"
                                    Margin="0,0,11,0"
                                    Background="{DynamicResource BrushSuccess}"
                                    CornerRadius="5"
                                    ToolTip="Kohana está activa" />
                            <Button x:Name="CommandPaletteButton"
                                    Width="42"
                                    Height="42"
                                    Padding="0"
                                    Style="{StaticResource HeaderCommandButtonStyle}"
                                    Click="CommandPaletteButton_Click"
                                    ToolTip="Abrir comandos · Ctrl + Espacio">
                                <ContentControl Width="18"
                                                Height="18"
                                                Foreground="{DynamicResource BrushAccent}"
                                                Style="{StaticResource KohanaFlowerMarkStyle}" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="5,0,5,5"
                            Padding="17"
                            Background="#BC121923"
                            BorderBrush="#2DFFFFFF"
                            BorderThickness="1"
                            CornerRadius="25">
                        <ContentControl x:Name="ModuleHost" />
                    </Border>

                    <Grid Visibility="Collapsed">
                        <TextBlock x:Name="ClockText" Text="—" />
                        <TextBlock x:Name="DateText" Text="—" />
                        <TextBlock x:Name="HeaderCpuText" Text="—" />
                        <TextBlock x:Name="HeaderMemoryText" Text="—" />
                        <TextBlock x:Name="HeaderGpuText" Text="—" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
