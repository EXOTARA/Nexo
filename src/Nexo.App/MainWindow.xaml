<Window x:Class="Nexo.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nexo"
        Width="420"
        Height="760"
        MinWidth="380"
        MinHeight="620"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closed="Window_Closed">

    <Border x:Name="ShellBorder"
            Margin="10"
            Background="{DynamicResource BrushBackground}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="20"
            Opacity="0"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28"
                              ShadowDepth="8"
                              Opacity="0.42"
                              Color="#000000" />
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="ShellTranslate" X="34" />
        </Border.RenderTransform>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="2,0,2,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="NEXO"
                                   Foreground="{DynamicResource BrushAccent}"
                                   FontWeight="Bold"
                                   FontSize="13" />
                        <Border Margin="9,0,0,0"
                                Padding="7,2"
                                Background="{DynamicResource BrushAccentSoft}"
                                CornerRadius="8">
                            <TextBlock Text="ALPHA"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="9"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border x:Name="WakeWordIndicator"
                                Margin="9,0,0,0"
                                Padding="7,2"
                                Background="{DynamicResource BrushSurfaceRaised}"
                                CornerRadius="8"
                                Visibility="Collapsed"
                                ToolTip="La activación por voz está escuchando únicamente la frase configurada.">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6"
                                         Height="6"
                                         Margin="0,0,5,0"
                                         VerticalAlignment="Center"
                                         Fill="{DynamicResource BrushSuccess}" />
                                <TextBlock x:Name="WakeWordIndicatorText"
                                           Text="Nexo atento"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           FontSize="9"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="ClockText"
                               Margin="0,5,0,0"
                               FontSize="30"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="DateText" Style="{StaticResource MutedTextStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button x:Name="PeekButton"
                            Style="{StaticResource IconButtonStyle}"
                            Content="◉"
                            ToolTip="Vista rápida (Alt + Shift + A)"
                            Click="PeekButton_Click" />
                    <Button x:Name="SettingsButton"
                            Margin="8,0,0,0"
                            Style="{StaticResource IconButtonStyle}"
                            Content="⚙"
                            FontFamily="Segoe UI Symbol"
                            ToolTip="Personalización"
                            Click="SettingsButton_Click" />
                    <Button Margin="8,0,0,0"
                            Style="{StaticResource IconButtonStyle}"
                            Content="—"
                            ToolTip="Ocultar"
                            Click="HideButton_Click" />
                    <Button Margin="8,0,0,0"
                            Style="{StaticResource IconButtonStyle}"
                            Content="×"
                            ToolTip="Salir"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>

            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,14">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="CPU" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock x:Name="HeaderCpuText" Text="—" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="3,0">
                    <StackPanel>
                        <TextBlock Text="RAM" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock x:Name="HeaderMemoryText" Text="—" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="GPU" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock x:Name="HeaderGpuText" Text="—" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="16">
                <ContentControl x:Name="ModuleHost" />
            </Border>

            <Border Grid.Row="3"
                    Margin="0,14,0,0"
                    Background="{DynamicResource BrushSurface}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="6">
                <UniformGrid x:Name="NavigationGrid" Columns="7">
                    <Button x:Name="AssistantNavButton"
                            Tag="Assistant"
                            Content="IA"
                            Click="NavigationButton_Click"
                            Style="{StaticResource NavButtonStyle}" />
                    <Button x:Name="TasksNavButton"
                            Tag="Tasks"
                            Content="Hoy"
                            Click="NavigationButton_Click"
                            Style="{StaticResource NavButtonStyle}" />
                    <Button x:Name="FocusNavButton"
                            Tag="Focus"
                            Content="Enfoque"
                            Click="NavigationButton_Click"
                            Style="{StaticResource NavButtonStyle}" />
                    <Button x:Name="RoutinesNavButton"
                            Tag="Routines"
                            Content="Rutinas"
                            Click="NavigationButton_Click"
                            Style="{StaticResource NavButtonStyle}" />
                    <Button x:Name="AudioNavButton"
                            Tag="Audio"
                            Content="Audio"
                            Click="NavigationButton_Click"
                            Style="{StaticResource NavButtonStyle}" />
                    <Button x:Name="CaptureNavButton"
                            Tag="Capture"
                            Content="Captura"
                            Click="NavigationButton_Click"
                            Style="{StaticResource NavButtonStyle}" />
                    <Button x:Name="SystemNavButton"
                            Tag="System"
                            Content="Sistema"
                            Click="NavigationButton_Click"
                            Style="{StaticResource NavButtonStyle}" />
                </UniformGrid>
            </Border>
        </Grid>
    </Border>
</Window>
