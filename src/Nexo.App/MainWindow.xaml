<Window x:Class="Nexo.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nexo"
        Width="420"
        Height="760"
        MinWidth="380"
        MinHeight="620"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closed="Window_Closed">

    <Border x:Name="ShellBorder"
            Margin="10"
            Background="{StaticResource BrushBackground}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="20"
            Opacity="0"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28"
                              ShadowDepth="8"
                              Opacity="0.42"
                              Color="#000000" />
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="ShellTranslate" X="34" />
        </Border.RenderTransform>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <Grid Grid.Row="0" Margin="2,0,2,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="NEXO"
                                   Foreground="{StaticResource BrushAccent}"
                                   FontWeight="Bold"
                                   FontSize="13" />
                        <Border Margin="9,0,0,0"
                                Padding="7,2"
                                Background="{StaticResource BrushAccentSoft}"
                                CornerRadius="8">
                            <TextBlock Text="ALPHA"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontSize="9"
                                       FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="ClockText"
                               Margin="0,5,0,0"
                               FontSize="30"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="DateText"
                               Style="{StaticResource MutedTextStyle}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="—"
                            ToolTip="Ocultar"
                            Click="HideButton_Click" />
                    <Button Margin="8,0,0,0"
                            Style="{StaticResource IconButtonStyle}"
                            Content="×"
                            ToolTip="Salir"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>

            <!-- Estado rápido -->
            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,14">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="CPU" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock Text="—" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="3,0">
                    <StackPanel>
                        <TextBlock Text="RAM" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock Text="—" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="ESTADO" Style="{StaticResource MutedTextStyle}" />
                        <TextBlock Text="Listo"
                                   Foreground="{StaticResource BrushSuccess}"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Área modular -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="16">
                <Grid>
                    <Grid x:Name="AssistantView">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="¿Qué necesitas?"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0"
                                       Text="Escribe una consulta o una orden local."
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>

                        <ScrollViewer x:Name="ConversationScroll"
                                      Grid.Row="1"
                                      Margin="0,16,0,14"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ConversationPanel">
                                <Border Background="{StaticResource BrushSurfaceRaised}"
                                        CornerRadius="13"
                                        Padding="12"
                                        HorizontalAlignment="Left"
                                        MaxWidth="310">
                                    <TextBlock Text="Hola. Esta es la nueva base de Nexo. Por ahora puedo probar la interfaz y los comandos locales que iremos agregando."
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource BrushTextPrimary}" />
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="PromptBox"
                                     Height="74"
                                     AcceptsReturn="True"
                                     Style="{StaticResource PromptTextBoxStyle}"
                                     PreviewKeyDown="PromptBox_PreviewKeyDown" />
                            <Button Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Width="74"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Enviar"
                                    Click="SendButton_Click" />
                        </Grid>
                    </Grid>

                    <Grid x:Name="AudioView" Visibility="Collapsed" Opacity="0">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Audio" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Aquí aparecerá el mezclador por aplicación."
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="CaptureView" Visibility="Collapsed" Opacity="0">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Captura" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Captura, edición y análisis con IA."
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="SystemView" Visibility="Collapsed" Opacity="0">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Sistema" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Métricas, procesos y perfiles reversibles."
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Navegación -->
            <Border Grid.Row="3"
                    Margin="0,14,0,0"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="6">
                <UniformGrid Columns="4">
                    <Button x:Name="AssistantNavButton"
                            Tag="Assistant"
                            Content="IA"
                            Click="NavigationButton_Click"
                            Style="{StaticResource NavButtonStyle}"
                            Background="{StaticResource BrushAccentSoft}"
                            Foreground="{StaticResource BrushTextPrimary}" />
                    <Button x:Name="AudioNavButton"
                            Tag="Audio"
                            Content="Audio"
                            Click="NavigationButton_Click"
                            Style="{StaticResource NavButtonStyle}" />
                    <Button x:Name="CaptureNavButton"
                            Tag="Capture"
                            Content="Captura"
                            Click="NavigationButton_Click"
                            Style="{StaticResource NavButtonStyle}" />
                    <Button x:Name="SystemNavButton"
                            Tag="System"
                            Content="Sistema"
                            Click="NavigationButton_Click"
                            Style="{StaticResource NavButtonStyle}" />
                </UniformGrid>
            </Border>
        </Grid>
    </Border>
</Window>
