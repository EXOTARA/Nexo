<UserControl x:Class="Nexo.App.Views.AssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="¿Qué necesitas?" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Margin="0,4,0,0"
                           Text="Escribe una consulta, usa Mirar o mantén Mic para hablar."
                           Style="{StaticResource MutedTextStyle}" />
                <TextBlock x:Name="AiProviderStatusText"
                           Margin="0,4,0,0"
                           Text="IA desactivada · los comandos locales siguen disponibles"
                           TextTrimming="CharacterEllipsis"
                           Style="{StaticResource MutedTextStyle}" />
            </StackPanel>

            <Button Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="10,6"
                    VerticalAlignment="Top"
                    Content="Limpiar"
                    ToolTip="Vaciar la conversación visible"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="ClearConversationButton_Click" />
        </Grid>

        <ScrollViewer x:Name="ConversationScroll"
                      Grid.Row="1"
                      Margin="0,16,0,10"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ConversationPanel" />
        </ScrollViewer>

        <Border x:Name="VisionAttachmentPanel"
                Grid.Row="2"
                Margin="0,0,0,10"
                Padding="8"
                Visibility="Collapsed"
                CornerRadius="12"
                Background="{StaticResource BrushSurfaceRaised}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="74" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="68"
                        Height="54"
                        CornerRadius="8"
                        ClipToBounds="True"
                        Background="#080A0F">
                    <Image x:Name="VisionPreviewImage"
                           Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="9,0,8,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Captura lista"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="VisionSourceTitleText"
                               Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource MutedTextStyle}" />
                    <TextBlock Margin="0,2,0,0"
                               Text="Se enviará solo con tu siguiente consulta."
                               Style="{StaticResource MutedTextStyle}" />
                </StackPanel>

                <Button Grid.Column="2"
                        Width="30"
                        Height="30"
                        Padding="0"
                        VerticalAlignment="Center"
                        Content="×"
                        ToolTip="Descartar captura"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="DiscardVisionButton_Click" />
            </Grid>
        </Border>

        <TextBlock x:Name="VoiceStatusText"
                   Grid.Row="3"
                   Margin="2,0,0,8"
                   Text="Preparando reconocimiento local…"
                   TextTrimming="CharacterEllipsis"
                   Style="{StaticResource MutedTextStyle}" />

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="PromptBox"
                     Height="74"
                     AcceptsReturn="True"
                     Style="{StaticResource PromptTextBoxStyle}"
                     PreviewKeyDown="PromptBox_PreviewKeyDown" />

            <Button x:Name="VisionButton"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Width="58"
                    Content="Mirar"
                    ToolTip="Capturar una ventana o monitor para preguntarle a Nexo"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="VisionButton_Click" />

            <Button x:Name="MicButton"
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    Width="58"
                    IsEnabled="False"
                    Content="Mic"
                    ToolTip="Mantén presionado para hablar"
                    Style="{StaticResource SecondaryButtonStyle}"
                    PreviewMouseLeftButtonDown="MicButton_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="MicButton_PreviewMouseLeftButtonUp"
                    LostMouseCapture="MicButton_LostMouseCapture"
                    PreviewKeyDown="MicButton_PreviewKeyDown"
                    PreviewKeyUp="MicButton_PreviewKeyUp" />

            <Button Grid.Column="3"
                    Margin="10,0,0,0"
                    Width="74"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Content="Enviar"
                    Click="SendButton_Click" />
        </Grid>
    </Grid>
</UserControl>
