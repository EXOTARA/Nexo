<Window x:Class="Nexo.App.CommandPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Comandos de Nexo"
        Width="680"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        PreviewKeyDown="Window_PreviewKeyDown"
        Deactivated="Window_Deactivated"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Style x:Key="PaletteIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface"
                                        Property="Background"
                                        Value="{DynamicResource BrushSurfaceRaised}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource BrushTextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.68" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuggestionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemSurface"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="11">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="26"
                                        Height="26"
                                        Background="{DynamicResource BrushAccentSoft}"
                                        CornerRadius="8">
                                    <TextBlock Text="↗"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource BrushAccent}"
                                               FontSize="12" />
                                </Border>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="10,0,10,0"
                                                  VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="Enter"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           FontSize="10" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemSurface"
                                        Property="Background"
                                        Value="{DynamicResource BrushSurfaceRaised}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemSurface"
                                        Property="Background"
                                        Value="{DynamicResource BrushAccentSoft}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MotionChipStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceRaised}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChipSurface"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipSurface" Property="Opacity" Value="0.82" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource BrushTextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChipSurface" Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Margin="22"
            Padding="10"
            Background="#F211131A"
            BorderBrush="#5AFFFFFF"
            BorderThickness="1"
            CornerRadius="24"
            Opacity="0"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="42"
                              ShadowDepth="10"
                              Opacity="0.48"
                              Color="#000000" />
        </Border.Effect>
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="PaletteScale"
                                ScaleX="0.985"
                                ScaleY="0.985" />
                <TranslateTransform x:Name="PaletteTranslate" Y="-10" />
            </TransformGroup>
        </Border.RenderTransform>
        <Border.RenderTransformOrigin>0.5,0.2</Border.RenderTransformOrigin>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="42"
                        Height="42"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Background="{DynamicResource BrushAccentSoft}"
                        CornerRadius="13">
                    <TextBlock Text="✦"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BrushAccent}"
                               FontSize="17"
                               FontWeight="SemiBold" />
                </Border>

                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <TextBox x:Name="PromptTextBox"
                             MinHeight="44"
                             Padding="0,7"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource BrushTextPrimary}"
                             CaretBrush="{DynamicResource BrushAccent}"
                             FontSize="18"
                             FontWeight="Normal"
                             TextChanged="PromptTextBox_TextChanged"
                             SelectionBrush="{DynamicResource BrushAccentSoft}" />
                    <TextBlock x:Name="PlaceholderText"
                               Text="¿Qué quieres hacer?"
                               Margin="1,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="18"
                               IsHitTestVisible="False" />
                </Grid>

                <Button Grid.Column="2"
                        x:Name="ExpandButton"
                        Margin="8,0,0,0"
                        Style="{StaticResource PaletteIconButtonStyle}"
                        Content="⌄"
                        FontSize="16"
                        ToolTip="Mostrar sugerencias (Tab)"
                        Click="ExpandButton_Click" />

                <Button Grid.Column="3"
                        x:Name="CustomizeButton"
                        Margin="4,0,0,0"
                        Style="{StaticResource PaletteIconButtonStyle}"
                        Content="❈"
                        FontFamily="Segoe UI Symbol"
                        FontSize="14"
                        ToolTip="Movimiento y apariencia"
                        Click="CustomizeButton_Click" />
            </Grid>

            <Border Grid.Row="1"
                    x:Name="ExpandedSurface"
                    Margin="4,8,4,2"
                    Padding="6"
                    Background="#851A1D26"
                    BorderBrush="#28FFFFFF"
                    BorderThickness="1"
                    CornerRadius="16"
                    Visibility="Collapsed"
                    Opacity="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ListBox x:Name="SuggestionsList"
                             MaxHeight="230"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource SuggestionItemStyle}"
                             MouseDoubleClick="SuggestionsList_MouseDoubleClick"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" />

                    <Grid Grid.Row="1" Margin="10,7,10,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Ctrl + Espacio"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="10" />
                            <TextBlock Text="  ·  "
                                       Foreground="{DynamicResource BrushBorder}"
                                       FontSize="10" />
                            <TextBlock Text="Esc para cerrar"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="10" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock x:Name="TimingText"
                                       Margin="0,0,12,0"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="10" />
                            <TextBlock Text="Ctrl + Enter abre Nexo"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="10" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    x:Name="CustomizationSurface"
                    Margin="4,8,4,2"
                    Padding="12"
                    Background="#B5222633"
                    BorderBrush="#30FFFFFF"
                    BorderThickness="1"
                    CornerRadius="16"
                    Visibility="Collapsed"
                    Opacity="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Movimiento"
                                       FontWeight="SemiBold"
                                       FontSize="12" />
                            <TextBlock Text="Sutil por defecto; cambia la sensación sin recargar Nexo."
                                       Margin="0,2,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                        <CheckBox Grid.Column="1"
                                  x:Name="ReduceMotionCheckBox"
                                  Content="Reducir movimiento"
                                  VerticalAlignment="Center"
                                  Checked="ReduceMotionCheckBox_Changed"
                                  Unchecked="ReduceMotionCheckBox_Changed" />
                    </Grid>

                    <WrapPanel Grid.Row="1" Margin="0,12,0,0">
                        <Button x:Name="FluidMotionButton"
                                Tag="Fluid"
                                Style="{StaticResource MotionChipStyle}"
                                Content="Fluido"
                                Click="MotionPresetButton_Click" />
                        <Button x:Name="SnappyMotionButton"
                                Tag="Snappy"
                                Style="{StaticResource MotionChipStyle}"
                                Content="Rápido"
                                Click="MotionPresetButton_Click" />
                        <Button x:Name="CalmMotionButton"
                                Tag="Calm"
                                Style="{StaticResource MotionChipStyle}"
                                Content="Calmo"
                                Click="MotionPresetButton_Click" />
                        <Button x:Name="NoMotionButton"
                                Tag="None"
                                Style="{StaticResource MotionChipStyle}"
                                Content="Sin movimiento"
                                Click="MotionPresetButton_Click" />
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
