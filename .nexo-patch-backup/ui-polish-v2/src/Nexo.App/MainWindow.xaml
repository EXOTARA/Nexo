<Window x:Class="Nexo.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nexo"
        Width="460"
        Height="760"
        MinWidth="400"
        MinHeight="620"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing"
        Closed="Window_Closed"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <Style x:Key="SideNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="320" />
            <Setter Property="ToolTipService.ShowDuration" Value="2800" />
            <Setter Property="ToolTipService.Placement" Value="Right" />
        </Style>

        <Style x:Key="CommandSurfaceButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
            <Setter Property="Background" Value="#B4151821" />
            <Setter Property="BorderBrush" Value="#32FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CommandSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CommandSurface"
                                        Property="Background"
                                        Value="{DynamicResource BrushSurfaceRaised}" />
                                <Setter TargetName="CommandSurface"
                                        Property="BorderBrush"
                                        Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CommandSurface" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="ShellBorder"
            Margin="10"
            BorderBrush="#48FFFFFF"
            BorderThickness="1"
            CornerRadius="24"
            Opacity="0"
            SnapsToDevicePixels="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F511131A" Offset="0" />
                <GradientStop Color="#F313151D" Offset="0.68" />
                <GradientStop Color="#F41A1725" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="34"
                              ShadowDepth="8"
                              Opacity="0.44"
                              Color="#000000" />
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="ShellTranslate" X="34" />
        </Border.RenderTransform>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="58" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,10,0"
                    Padding="8,10"
                    Background="#801A1D26"
                    BorderBrush="#28FFFFFF"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Width="34"
                            Height="34"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource BrushAccentSoft}"
                            CornerRadius="11"
                            ToolTip="Nexo">
                        <TextBlock Text="✦"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource BrushAccent}"
                                   FontSize="15"
                                   FontWeight="SemiBold" />
                    </Border>

                    <StackPanel Grid.Row="1"
                                x:Name="NavigationGrid"
                                Margin="0,13,0,8"
                                VerticalAlignment="Top">
                        <Button x:Name="AssistantNavButton"
                                Tag="Assistant"
                                Content="✦"
                                ToolTip="Asistente"
                                Click="NavigationButton_Click"
                                Style="{StaticResource SideNavButtonStyle}" />
                        <Button x:Name="TasksNavButton"
                                Tag="Tasks"
                                Content="✓"
                                ToolTip="Hoy"
                                Click="NavigationButton_Click"
                                Style="{StaticResource SideNavButtonStyle}" />
                        <Button x:Name="FocusNavButton"
                                Tag="Focus"
                                Content="◎"
                                ToolTip="Enfoque"
                                Click="NavigationButton_Click"
                                Style="{StaticResource SideNavButtonStyle}" />
                        <Button x:Name="RoutinesNavButton"
                                Tag="Routines"
                                Content="↻"
                                ToolTip="Rutinas"
                                Click="NavigationButton_Click"
                                Style="{StaticResource SideNavButtonStyle}" />
                        <Button x:Name="AudioNavButton"
                                Tag="Audio"
                                Content="♪"
                                ToolTip="Audio"
                                Click="NavigationButton_Click"
                                Style="{StaticResource SideNavButtonStyle}" />
                        <Button x:Name="CaptureNavButton"
                                Tag="Capture"
                                Content="▣"
                                ToolTip="Captura"
                                Click="NavigationButton_Click"
                                Style="{StaticResource SideNavButtonStyle}" />
                        <Button x:Name="SystemNavButton"
                                Tag="System"
                                Content="⌁"
                                ToolTip="Sistema"
                                Click="NavigationButton_Click"
                                Style="{StaticResource SideNavButtonStyle}" />
                    </StackPanel>

                    <Button Grid.Row="2"
                            x:Name="SettingsNavButton"
                            Tag="Settings"
                            Content="❈"
                            FontFamily="Segoe UI Symbol"
                            ToolTip="Personalización y perfiles"
                            Click="SettingsButton_Click"
                            Style="{StaticResource SideNavButtonStyle}" />
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="4,2,4,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="NEXO"
                                       Foreground="{DynamicResource BrushAccent}"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <Border Margin="9,0,0,0"
                                    Padding="7,2"
                                    Background="{DynamicResource BrushAccentSoft}"
                                    CornerRadius="8">
                                <TextBlock Text="ALPHA"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           FontSize="9"
                                           FontWeight="SemiBold" />
                            </Border>
                            <Border x:Name="WakeWordIndicator"
                                    Margin="9,0,0,0"
                                    Padding="7,2"
                                    Background="{DynamicResource BrushSurfaceRaised}"
                                    CornerRadius="8"
                                    Visibility="Collapsed"
                                    ToolTip="La activación por voz escucha únicamente la frase configurada.">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6"
                                             Height="6"
                                             Margin="0,0,5,0"
                                             VerticalAlignment="Center"
                                             Fill="{DynamicResource BrushSuccess}" />
                                    <TextBlock x:Name="WakeWordIndicatorText"
                                               Text="Nexo atento"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               FontSize="9"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Margin="0,7,0,0" Orientation="Horizontal">
                            <TextBlock x:Name="ClockText"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="  ·  "
                                       Foreground="{DynamicResource BrushBorder}"
                                       FontSize="12"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="DateText"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Button Grid.Row="1"
                        x:Name="CommandPaletteButton"
                        Margin="4,0,4,12"
                        Style="{StaticResource CommandSurfaceButtonStyle}"
                        Click="CommandPaletteButton_Click"
                        ToolTip="Abrir comandos con Ctrl + Espacio">
                    <Grid Margin="13,11">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="31"
                                Height="31"
                                Background="{DynamicResource BrushAccentSoft}"
                                CornerRadius="10">
                            <TextBlock Text="✦"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource BrushAccent}"
                                       FontSize="13" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Margin="10,0,10,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="¿Qué quieres hacer?"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Comandos, voz y contexto"
                                       Margin="0,2,0,0"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="10" />
                        </StackPanel>
                        <Border Grid.Column="2"
                                Padding="8,5"
                                VerticalAlignment="Center"
                                Background="{DynamicResource BrushSurfaceRaised}"
                                CornerRadius="8">
                            <TextBlock Text="Ctrl + Espacio"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="9" />
                        </Border>
                    </Grid>
                </Button>

                <Border Grid.Row="2"
                        Margin="4,0,4,4"
                        Padding="14"
                        Background="#A31A1D26"
                        BorderBrush="#30FFFFFF"
                        BorderThickness="1"
                        CornerRadius="18">
                    <ContentControl x:Name="ModuleHost" />
                </Border>

                <!-- Conservamos los medidores para las funciones existentes,
                     pero dejan de ocupar espacio visual permanente. -->
                <Grid Visibility="Collapsed">
                    <TextBlock x:Name="HeaderCpuText" Text="—" />
                    <TextBlock x:Name="HeaderMemoryText" Text="—" />
                    <TextBlock x:Name="HeaderGpuText" Text="—" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
