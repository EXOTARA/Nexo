<Window x:Class="Nexo.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nexo"
        Width="504"
        Height="792"
        MinWidth="468"
        MinHeight="660"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing"
        Closed="Window_Closed"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <Style x:Key="SideNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Width" Value="158" />
            <Setter Property="Height" Value="44" />
            <Setter Property="MinWidth" Value="158" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="240" />
            <Setter Property="ToolTipService.ShowDuration" Value="3000" />
            <Setter Property="ToolTipService.Placement" Value="Right" />
        </Style>

        <Style x:Key="CommandSurfaceButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
            <Setter Property="Background" Value="#B30F141D" />
            <Setter Property="BorderBrush" Value="#32FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CommandSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="19">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CommandSurface"
                                        Property="Background"
                                        Value="{DynamicResource BrushSurfaceHover}" />
                                <Setter TargetName="CommandSurface"
                                        Property="BorderBrush"
                                        Value="{DynamicResource BrushAccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="CommandSurface"
                                        Property="BorderBrush"
                                        Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CommandSurface" Property="Opacity" Value="0.76" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="ShellBorder"
            Margin="16"
            Background="{DynamicResource BrushBackground}"
            BorderThickness="1"
            CornerRadius="30"
            Opacity="0"
            SnapsToDevicePixels="True">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#74FFFFFF" Offset="0" />
                <GradientStop Color="#22FFFFFF" Offset="0.44" />
                <GradientStop Color="#468B6CFF" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="34"
                              ShadowDepth="9"
                              Opacity="0.44"
                              Color="#000000" />
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="ShellTranslate" X="34" />
        </Border.RenderTransform>

        <Grid ClipToBounds="True">
            <Border CornerRadius="29">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3A1A2230" Offset="0" />
                        <GradientStop Color="#0B0D1119" Offset="0.52" />
                        <GradientStop Color="#351D1828" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Border Height="1"
                    Margin="28,1,28,0"
                    VerticalAlignment="Top"
                    CornerRadius="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00FFFFFF" Offset="0" />
                        <GradientStop Color="#70FFFFFF" Offset="0.5" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid Margin="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="SideRailBorder"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Panel.ZIndex="8"
                        Width="68"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Padding="7,10"
                        Background="#F2161C27"
                        BorderBrush="#36FFFFFF"
                        BorderThickness="1"
                        CornerRadius="21"
                        ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20"
                                          ShadowDepth="5"
                                          Opacity="0.26"
                                          Color="#000000" />
                    </Border.Effect>
                    <Grid Width="158" HorizontalAlignment="Left">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Button x:Name="SideRailToggleButton"
                                Width="158"
                                Height="46"
                                HorizontalAlignment="Left"
                                HorizontalContentAlignment="Left"
                                Padding="4,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                FocusVisualStyle="{x:Null}"
                                ToolTip="Expandir o contraer navegación"
                                Click="SideRailToggleButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="40"
                                        Height="40"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource BrushAccentSoft}"
                                        BorderBrush="{DynamicResource BrushAccentBorder}"
                                        BorderThickness="1"
                                        CornerRadius="13">
                                    <TextBlock Text="✦"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource BrushAccent}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Nexo"
                                               FontSize="14"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="navegación"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource BrushTextTertiary}"
                                               FontSize="11" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <StackPanel Grid.Row="1"
                                    x:Name="NavigationGrid"
                                    Margin="0,12,0,8"
                                    VerticalAlignment="Top">
                            <Button x:Name="AssistantNavButton"
                                    Tag="Assistant"
                                    ToolTip="Asistente"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="✦"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="18" />
                                    <TextBlock Grid.Column="1"
                                               Margin="9,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="Asistente"
                                               FontSize="13.5" />
                                </Grid>
                            </Button>
                            <Button x:Name="TasksNavButton"
                                    Tag="Tasks"
                                    ToolTip="Pendientes de hoy"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="✓" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="19" />
                                    <TextBlock Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center" Text="Hoy" FontSize="13.5" />
                                </Grid>
                            </Button>
                            <Button x:Name="FocusNavButton"
                                    Tag="Focus"
                                    ToolTip="Enfoque"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="◎" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="19" />
                                    <TextBlock Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center" Text="Enfoque" FontSize="13.5" />
                                </Grid>
                            </Button>
                            <Button x:Name="RoutinesNavButton"
                                    Tag="Routines"
                                    ToolTip="Rutinas"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="↻" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                                    <TextBlock Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center" Text="Rutinas" FontSize="13.5" />
                                </Grid>
                            </Button>
                            <Button x:Name="AudioNavButton"
                                    Tag="Audio"
                                    ToolTip="Audio"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="♪" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                                    <TextBlock Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center" Text="Audio" FontSize="13.5" />
                                </Grid>
                            </Button>
                            <Button x:Name="CaptureNavButton"
                                    Tag="Capture"
                                    ToolTip="Captura"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="▣" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="17" />
                                    <TextBlock Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center" Text="Captura" FontSize="13.5" />
                                </Grid>
                            </Button>
                            <Button x:Name="SystemNavButton"
                                    Tag="System"
                                    ToolTip="Sistema"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="⌁" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" />
                                    <TextBlock Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center" Text="Sistema" FontSize="13.5" />
                                </Grid>
                            </Button>
                        </StackPanel>

                        <Button Grid.Row="2"
                                x:Name="SettingsNavButton"
                                Tag="Settings"
                                ToolTip="Personalización y perfiles"
                                Click="SettingsButton_Click"
                                Style="{StaticResource SideNavButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="❈"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Symbol"
                                           FontSize="19" />
                                <TextBlock Grid.Column="1"
                                           Margin="9,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="Personalizar"
                                           FontSize="13.5" />
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="2,1,0,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="7,4,7,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="NEXO"
                                           Foreground="{DynamicResource BrushAccent}"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                                <Border Margin="10,0,0,0"
                                        Padding="8,3"
                                        Background="{DynamicResource BrushAccentSoft}"
                                        CornerRadius="9">
                                    <TextBlock Text="ALPHA"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               FontSize="10.5"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Border x:Name="WakeWordIndicator"
                                        Margin="10,0,0,0"
                                        Padding="8,3"
                                        Background="{DynamicResource BrushSurfaceRaised}"
                                        CornerRadius="9"
                                        Visibility="Collapsed"
                                        ToolTip="La activación por voz escucha únicamente la frase configurada.">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7"
                                                 Height="7"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{DynamicResource BrushSuccess}" />
                                        <TextBlock x:Name="WakeWordIndicatorText"
                                                   Text="Nexo atento"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                <TextBlock x:Name="ClockText"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="  ·  "
                                           Foreground="{DynamicResource BrushBorder}"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="DateText"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="8"
                                Height="8"
                                Margin="0,5,2,0"
                                VerticalAlignment="Top"
                                Background="{DynamicResource BrushSuccess}"
                                CornerRadius="4"
                                ToolTip="Nexo está activo" />
                    </Grid>

                    <Button Grid.Row="1"
                            x:Name="CommandPaletteButton"
                            Margin="7,0,7,14"
                            Style="{StaticResource CommandSurfaceButtonStyle}"
                            Click="CommandPaletteButton_Click"
                            ToolTip="Abrir comandos con Ctrl + Espacio">
                        <Grid Margin="14,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="38"
                                    Height="38"
                                    Background="{DynamicResource BrushAccentSoft}"
                                    BorderBrush="{DynamicResource BrushAccentBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <TextBlock Text="✦"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource BrushAccent}"
                                           FontSize="16" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Margin="12,0,11,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="¿Qué quieres hacer?"
                                           FontSize="15"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Acciones, voz y contexto"
                                           Margin="0,3,0,0"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           FontSize="12" />
                            </StackPanel>
                            <Border Grid.Column="2"
                                    Padding="9,6"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource BrushSurfaceRaised}"
                                    CornerRadius="9">
                                <TextBlock Text="Ctrl + Espacio"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           FontSize="10.5" />
                            </Border>
                        </Grid>
                    </Button>

                    <Border Grid.Row="2"
                            Margin="7,0,7,7"
                            Padding="16"
                            BorderBrush="#2DFFFFFF"
                            BorderThickness="1"
                            CornerRadius="23">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#D0141A24" Offset="0" />
                                <GradientStop Color="#B0181E2A" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentControl x:Name="ModuleHost" />
                    </Border>

                    <Grid Visibility="Collapsed">
                        <TextBlock x:Name="HeaderCpuText" Text="—" />
                        <TextBlock x:Name="HeaderMemoryText" Text="—" />
                        <TextBlock x:Name="HeaderGpuText" Text="—" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
