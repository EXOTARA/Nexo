<Window x:Class="Nexo.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nexo"
        Width="670"
        Height="790"
        MinWidth="600"
        MinHeight="680"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing"
        Closed="Window_Closed"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <Geometry x:Key="IconHome">M3,9.5 L10,3 L17,9.5 L17,17 L12.5,17 L12.5,12.5 L7.5,12.5 L7.5,17 L3,17 Z</Geometry>
        <Geometry x:Key="IconSparkle">M10,1 L12.3,7.7 L19,10 L12.3,12.3 L10,19 L7.7,12.3 L1,10 L7.7,7.7 Z</Geometry>
        <Geometry x:Key="IconCheck">M3,10 L7.2,14.2 L17,4.5</Geometry>
        <Geometry x:Key="IconRoutine">M4,7 C6,3 14,3 16,7 M16,4 L16,8 L12,8 M16,13 C14,17 6,17 4,13 M4,16 L4,12 L8,12</Geometry>
        <Geometry x:Key="IconAudio">M12,3 L12,14 C12,16.2 10.2,18 8,18 C5.8,18 4,16.5 4,14.5 C4,12.5 5.8,11 8,11 C9,11 9.8,11.2 10.5,11.6 L10.5,5 L17,3.5 L17,6 L12,7.2</Geometry>
        <Geometry x:Key="IconCapture">M3,5 L17,5 L17,15 L3,15 Z M7,18 L13,18</Geometry>
        <Geometry x:Key="IconSystem">M2,11 L5,11 L7,6 L10,15 L13,9 L15,11 L18,11</Geometry>
        <Geometry x:Key="IconSettings">M10,1 L11.5,5.2 L15.5,3.4 L16.6,4.5 L14.8,8.5 L19,10 L14.8,11.5 L16.6,15.5 L15.5,16.6 L11.5,14.8 L10,19 L8.5,14.8 L4.5,16.6 L3.4,15.5 L5.2,11.5 L1,10 L5.2,8.5 L3.4,4.5 L4.5,3.4 L8.5,5.2 Z</Geometry>

        <Style x:Key="SideRailIconStyle" TargetType="Path">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            <Setter Property="StrokeThickness" Value="1.8" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
        </Style>

        <Style x:Key="FilledSideRailIconStyle"
               TargetType="Path"
               BasedOn="{StaticResource SideRailIconStyle}">
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        </Style>

        <Style x:Key="SideNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Width" Value="178" />
            <Setter Property="Height" Value="46" />
            <Setter Property="MinWidth" Value="178" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="260" />
            <Setter Property="ToolTipService.ShowDuration" Value="3200" />
            <Setter Property="ToolTipService.Placement" Value="Right" />
        </Style>

        <Style x:Key="HeaderCommandButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceRaised}" />
            <Setter Property="BorderBrush" Value="#2EFFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="{DynamicResource BrushSurfaceHover}" />
                                <Setter TargetName="Surface" Property="BorderBrush" Value="{DynamicResource BrushAccentBorder}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Surface" Property="BorderBrush" Value="{DynamicResource BrushAccent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="ShellBorder"
            Margin="16"
            Background="{DynamicResource BrushBackground}"
            BorderThickness="1"
            CornerRadius="30"
            Opacity="0"
            SnapsToDevicePixels="True">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#70FFFFFF" Offset="0" />
                <GradientStop Color="#20FFFFFF" Offset="0.45" />
                <GradientStop Color="#458B6CFF" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="38"
                              ShadowDepth="10"
                              Opacity="0.45"
                              Color="#000000" />
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="ShellTranslate" X="24" />
        </Border.RenderTransform>

        <Grid ClipToBounds="True">
            <Border CornerRadius="29">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#32192331" Offset="0" />
                        <GradientStop Color="#0D101820" Offset="0.52" />
                        <GradientStop Color="#2B171A29" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Ellipse Width="280"
                     Height="280"
                     Margin="-120,-140,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="#188B6CFF"
                     IsHitTestVisible="False">
                <Ellipse.Effect>
                    <BlurEffect Radius="65" />
                </Ellipse.Effect>
            </Ellipse>

            <Ellipse Width="220"
                     Height="220"
                     Margin="0,0,-100,-120"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Fill="#1255DFA4"
                     IsHitTestVisible="False">
                <Ellipse.Effect>
                    <BlurEffect Radius="70" />
                </Ellipse.Effect>
            </Ellipse>

            <Grid Margin="13">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="SideRailBorder"
                        Grid.Column="0"
                        Width="68"
                        Margin="0"
                        Padding="7,10"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Background="#F2161C27"
                        BorderBrush="#38FFFFFF"
                        BorderThickness="1"
                        CornerRadius="22"
                        ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22"
                                          ShadowDepth="5"
                                          Opacity="0.28"
                                          Color="#000000" />
                    </Border.Effect>

                    <Grid Width="178" HorizontalAlignment="Left">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Button x:Name="SideRailToggleButton"
                                Width="178"
                                Height="48"
                                HorizontalAlignment="Left"
                                HorizontalContentAlignment="Left"
                                Padding="4,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                FocusVisualStyle="{x:Null}"
                                ToolTip="Expandir o contraer navegación"
                                Click="SideRailToggleButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="42"
                                        Height="42"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource BrushAccentSoft}"
                                        BorderBrush="{DynamicResource BrushAccentBorder}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Path Width="19"
                                          Height="19"
                                          Stretch="Uniform"
                                          Fill="{DynamicResource BrushAccent}"
                                          Data="{StaticResource IconSparkle}" />
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Nexo"
                                               FontSize="15"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="workspace"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource BrushTextTertiary}"
                                               FontSize="11.5" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <StackPanel Grid.Row="1"
                                    x:Name="NavigationGrid"
                                    Margin="0,14,0,8"
                                    VerticalAlignment="Top">
                            <Button x:Name="HomeNavButton"
                                    Tag="Home"
                                    ToolTip="Inicio"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconHome}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Inicio" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="AssistantNavButton"
                                    Tag="Assistant"
                                    ToolTip="Asistente"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource FilledSideRailIconStyle}" Data="{StaticResource IconSparkle}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Asistente" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="TasksNavButton"
                                    Tag="Tasks"
                                    ToolTip="Pendientes de hoy"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconCheck}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Hoy" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="FocusNavButton"
                                    Tag="Focus"
                                    ToolTip="Enfoque"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Width="20" Height="20" HorizontalAlignment="Center">
                                        <Ellipse Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" />
                                        <Ellipse Width="6" Height="6" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </Grid>
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Enfoque" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="RoutinesNavButton"
                                    Tag="Routines"
                                    ToolTip="Rutinas"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconRoutine}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Rutinas" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="AudioNavButton"
                                    Tag="Audio"
                                    ToolTip="Audio"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconAudio}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Audio" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="CaptureNavButton"
                                    Tag="Capture"
                                    ToolTip="Captura"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconCapture}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Captura" FontSize="14" />
                                </Grid>
                            </Button>

                            <Button x:Name="SystemNavButton"
                                    Tag="System"
                                    ToolTip="Sistema"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path Style="{StaticResource SideRailIconStyle}" Data="{StaticResource IconSystem}" />
                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Sistema" FontSize="14" />
                                </Grid>
                            </Button>
                        </StackPanel>

                        <Button Grid.Row="2"
                                x:Name="SettingsNavButton"
                                Tag="Settings"
                                ToolTip="Personalización y perfiles"
                                Click="SettingsButton_Click"
                                Style="{StaticResource SideNavButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Path Style="{StaticResource FilledSideRailIconStyle}" Data="{StaticResource IconSettings}" />
                                <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="Personalizar" FontSize="14" />
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="13,2,2,2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="5,4,5,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="WorkspaceTitleText"
                                           Text="Inicio"
                                           FontSize="23"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Border x:Name="WakeWordIndicator"
                                        Margin="11,1,0,0"
                                        Padding="8,3"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource BrushSurfaceRaised}"
                                        CornerRadius="9"
                                        Visibility="Collapsed"
                                        ToolTip="La activación por voz escucha únicamente la frase configurada.">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7"
                                                 Height="7"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{DynamicResource BrushSuccess}" />
                                        <TextBlock x:Name="WakeWordIndicatorText"
                                                   Text="Nexo atento"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <TextBlock x:Name="WorkspaceSubtitleText"
                                       Margin="0,5,0,0"
                                       Text="Tu espacio de acciones y contexto"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="12.5" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="9"
                                    Height="9"
                                    Margin="0,0,11,0"
                                    Background="{DynamicResource BrushSuccess}"
                                    CornerRadius="5"
                                    ToolTip="Nexo está activo" />
                            <Button x:Name="CommandPaletteButton"
                                    Style="{StaticResource HeaderCommandButtonStyle}"
                                    Click="CommandPaletteButton_Click"
                                    ToolTip="Abrir comandos con Ctrl + Espacio">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="14"
                                          Height="14"
                                          Margin="0,0,8,0"
                                          Stretch="Uniform"
                                          Fill="{DynamicResource BrushAccent}"
                                          Data="{StaticResource IconSparkle}" />
                                    <TextBlock Text="Comando"
                                               FontSize="12.5"
                                               FontWeight="SemiBold" />
                                    <Border Margin="9,0,0,0"
                                            Padding="7,3"
                                            Background="#28FFFFFF"
                                            CornerRadius="7">
                                        <TextBlock Text="Ctrl + Espacio"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontSize="9.5" />
                                    </Border>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="5,0,5,5"
                            Padding="17"
                            Background="#BC121923"
                            BorderBrush="#2DFFFFFF"
                            BorderThickness="1"
                            CornerRadius="25">
                        <ContentControl x:Name="ModuleHost" />
                    </Border>

                    <Grid Visibility="Collapsed">
                        <TextBlock x:Name="ClockText" Text="—" />
                        <TextBlock x:Name="DateText" Text="—" />
                        <TextBlock x:Name="HeaderCpuText" Text="—" />
                        <TextBlock x:Name="HeaderMemoryText" Text="—" />
                        <TextBlock x:Name="HeaderGpuText" Text="—" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
