<Window x:Class="Nexo.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nexo"
        Width="476"
        Height="780"
        MinWidth="440"
        MinHeight="640"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing"
        Closed="Window_Closed"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Style x:Key="SideNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="38" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ToolTipService.InitialShowDelay" Value="280" />
            <Setter Property="ToolTipService.ShowDuration" Value="3000" />
            <Setter Property="ToolTipService.Placement" Value="Right" />
        </Style>

        <Style x:Key="CommandSurfaceButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
            <Setter Property="Background" Value="#A8141720" />
            <Setter Property="BorderBrush" Value="#28FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CommandSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CommandSurface"
                                        Property="Background"
                                        Value="#C4222633" />
                                <Setter TargetName="CommandSurface"
                                        Property="BorderBrush"
                                        Value="#728B6CFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CommandSurface" Property="Opacity" Value="0.76" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="ShellBorder"
            Margin="14"
            Background="{DynamicResource BrushBackground}"
            BorderThickness="1"
            CornerRadius="28"
            Opacity="0"
            SnapsToDevicePixels="True">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#70FFFFFF" Offset="0" />
                <GradientStop Color="#20FFFFFF" Offset="0.44" />
                <GradientStop Color="#3C8B6CFF" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="36"
                              ShadowDepth="9"
                              Opacity="0.46"
                              Color="#000000" />
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="ShellTranslate" X="34" />
        </Border.RenderTransform>

        <Grid ClipToBounds="True">
            <Border CornerRadius="27">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#321E2430" Offset="0" />
                        <GradientStop Color="#0811131A" Offset="0.5" />
                        <GradientStop Color="#301D172A" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Border Height="1"
                    Margin="24,1,24,0"
                    VerticalAlignment="Top"
                    CornerRadius="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00FFFFFF" Offset="0" />
                        <GradientStop Color="#72FFFFFF" Offset="0.5" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="62" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,12,0"
                        Padding="8,11"
                        Background="#8A171A23"
                        BorderBrush="#2CFFFFFF"
                        BorderThickness="1"
                        CornerRadius="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Width="36"
                                Height="36"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource BrushAccentSoft}"
                                CornerRadius="12"
                                ToolTip="Nexo">
                            <TextBlock Text="✦"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource BrushAccent}"
                                       FontSize="15"
                                       FontWeight="SemiBold" />
                        </Border>

                        <StackPanel Grid.Row="1"
                                    x:Name="NavigationGrid"
                                    Margin="0,13,0,8"
                                    VerticalAlignment="Top">
                            <Button x:Name="AssistantNavButton"
                                    Tag="Assistant"
                                    Content="✦"
                                    ToolTip="Asistente"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}" />
                            <Button x:Name="TasksNavButton"
                                    Tag="Tasks"
                                    Content="✓"
                                    ToolTip="Hoy"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}" />
                            <Button x:Name="FocusNavButton"
                                    Tag="Focus"
                                    Content="◎"
                                    ToolTip="Enfoque"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}" />
                            <Button x:Name="RoutinesNavButton"
                                    Tag="Routines"
                                    Content="↻"
                                    ToolTip="Rutinas"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}" />
                            <Button x:Name="AudioNavButton"
                                    Tag="Audio"
                                    Content="♪"
                                    ToolTip="Audio"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}" />
                            <Button x:Name="CaptureNavButton"
                                    Tag="Capture"
                                    Content="▣"
                                    ToolTip="Captura"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}" />
                            <Button x:Name="SystemNavButton"
                                    Tag="System"
                                    Content="⌁"
                                    ToolTip="Sistema"
                                    Click="NavigationButton_Click"
                                    Style="{StaticResource SideNavButtonStyle}" />
                        </StackPanel>

                        <Button Grid.Row="2"
                                x:Name="SettingsNavButton"
                                Tag="Settings"
                                Content="❈"
                                FontFamily="Segoe UI Symbol"
                                ToolTip="Personalización y perfiles"
                                Click="SettingsButton_Click"
                                Style="{StaticResource SideNavButtonStyle}" />
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="5,3,5,13">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="NEXO"
                                           Foreground="{DynamicResource BrushAccent}"
                                           FontWeight="Bold"
                                           FontSize="13"
                                           VerticalAlignment="Center" />
                                <Border Margin="9,0,0,0"
                                        Padding="7,2"
                                        Background="{DynamicResource BrushAccentSoft}"
                                        CornerRadius="8">
                                    <TextBlock Text="ALPHA"
                                               Foreground="{DynamicResource BrushTextSecondary}"
                                               FontSize="9"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Border x:Name="WakeWordIndicator"
                                        Margin="9,0,0,0"
                                        Padding="7,2"
                                        Background="{DynamicResource BrushSurfaceRaised}"
                                        CornerRadius="8"
                                        Visibility="Collapsed"
                                        ToolTip="La activación por voz escucha únicamente la frase configurada.">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6"
                                                 Height="6"
                                                 Margin="0,0,5,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{DynamicResource BrushSuccess}" />
                                        <TextBlock x:Name="WakeWordIndicatorText"
                                                   Text="Nexo atento"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontSize="9"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Margin="0,7,0,0" Orientation="Horizontal">
                                <TextBlock x:Name="ClockText"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="  ·  "
                                           Foreground="{DynamicResource BrushBorder}"
                                           FontSize="12"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="DateText"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedTextStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="7"
                                Height="7"
                                Margin="0,4,2,0"
                                VerticalAlignment="Top"
                                Background="{DynamicResource BrushSuccess}"
                                CornerRadius="4"
                                ToolTip="Nexo está activo" />
                    </Grid>

                    <Button Grid.Row="1"
                            x:Name="CommandPaletteButton"
                            Margin="5,0,5,13"
                            Style="{StaticResource CommandSurfaceButtonStyle}"
                            Click="CommandPaletteButton_Click"
                            ToolTip="Abrir comandos con Ctrl + Espacio">
                        <Grid Margin="13,11">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="33"
                                    Height="33"
                                    Background="{DynamicResource BrushAccentSoft}"
                                    CornerRadius="11">
                                <TextBlock Text="✦"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource BrushAccent}"
                                           FontSize="13" />
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Margin="11,0,10,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="¿Qué quieres hacer?"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Acciones, voz y contexto"
                                           Margin="0,2,0,0"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           FontSize="10" />
                            </StackPanel>
                            <Border Grid.Column="2"
                                    Padding="8,5"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource BrushSurfaceRaised}"
                                    CornerRadius="8">
                                <TextBlock Text="Ctrl + Espacio"
                                           Foreground="{DynamicResource BrushTextSecondary}"
                                           FontSize="9" />
                            </Border>
                        </Grid>
                    </Button>

                    <Border Grid.Row="2"
                            Margin="5,0,5,5"
                            Padding="15"
                            BorderBrush="#26FFFFFF"
                            BorderThickness="1"
                            CornerRadius="22">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#B6171A23" Offset="0" />
                                <GradientStop Color="#9E1B1E28" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <ContentControl x:Name="ModuleHost" />
                    </Border>

                    <Grid Visibility="Collapsed">
                        <TextBlock x:Name="HeaderCpuText" Text="—" />
                        <TextBlock x:Name="HeaderMemoryText" Text="—" />
                        <TextBlock x:Name="HeaderGpuText" Text="—" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
