<UserControl x:Class="Nexo.App.Views.AssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="¿Qué necesitas?"
                           FontSize="19"
                           FontWeight="SemiBold" />
                <TextBlock Margin="0,4,0,0"
                           Text="Ordena algo, pregunta o comparte lo que estás viendo."
                           Foreground="{DynamicResource BrushTextSecondary}"
                           FontSize="11" />
                <Border Margin="0,8,0,0"
                        Padding="8,5"
                        HorizontalAlignment="Left"
                        Background="#56222633"
                        CornerRadius="9">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6"
                                 Height="6"
                                 Margin="0,0,7,0"
                                 VerticalAlignment="Center"
                                 Fill="{DynamicResource BrushSuccess}" />
                        <TextBlock x:Name="AiProviderStatusText"
                                   Text="IA desactivada · los comandos locales siguen disponibles"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   FontSize="10" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Button Grid.Column="1"
                    Width="34"
                    Height="34"
                    Margin="10,0,0,0"
                    Padding="0"
                    VerticalAlignment="Top"
                    Content="⌫"
                    FontSize="14"
                    ToolTip="Limpiar conversación"
                    Style="{StaticResource IconButtonStyle}"
                    Click="ClearConversationButton_Click" />
        </Grid>

        <ScrollViewer x:Name="ConversationScroll"
                      Grid.Row="1"
                      Margin="0,14,0,10"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ConversationPanel" />
        </ScrollViewer>

        <Border x:Name="VisionAttachmentPanel"
                Grid.Row="2"
                Margin="0,0,0,10"
                Padding="8"
                Visibility="Collapsed"
                CornerRadius="14"
                Background="#A0222633"
                BorderBrush="#32FFFFFF"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="74" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="68"
                        Height="54"
                        CornerRadius="10"
                        ClipToBounds="True"
                        Background="#080A0F">
                    <Image x:Name="VisionPreviewImage"
                           Stretch="UniformToFill" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="10,0,8,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Captura lista"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="VisionSourceTitleText"
                               Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis"
                               Style="{StaticResource MutedTextStyle}" />
                    <TextBlock Margin="0,2,0,0"
                               Text="Se enviará solo con tu siguiente consulta."
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="10" />
                </StackPanel>

                <Button Grid.Column="2"
                        Width="30"
                        Height="30"
                        Padding="0"
                        VerticalAlignment="Center"
                        Content="×"
                        ToolTip="Descartar captura"
                        Style="{StaticResource IconButtonStyle}"
                        Click="DiscardVisionButton_Click" />
            </Grid>
        </Border>

        <TextBlock x:Name="VoiceStatusText"
                   Grid.Row="3"
                   Margin="3,0,0,8"
                   Text="Preparando reconocimiento local…"
                   TextTrimming="CharacterEllipsis"
                   Foreground="{DynamicResource BrushTextSecondary}"
                   FontSize="10" />

        <Border Grid.Row="4"
                Padding="8"
                Background="#A812151D"
                BorderBrush="#3BFFFFFF"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="PromptBox"
                         MinHeight="54"
                         MaxHeight="112"
                         Padding="8,7"
                         AcceptsReturn="True"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         PreviewKeyDown="PromptBox_PreviewKeyDown" />

                <Button x:Name="VisionButton"
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        MinWidth="56"
                        Padding="11,9"
                        Content="Mirar"
                        ToolTip="Capturar una ventana o monitor para preguntarle a Nexo"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="VisionButton_Click" />

                <Button x:Name="MicButton"
                        Grid.Column="2"
                        Margin="8,0,0,0"
                        MinWidth="50"
                        Padding="11,9"
                        IsEnabled="False"
                        Content="Mic"
                        ToolTip="Mantén presionado para hablar"
                        Style="{StaticResource SecondaryButtonStyle}"
                        PreviewMouseLeftButtonDown="MicButton_PreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="MicButton_PreviewMouseLeftButtonUp"
                        LostMouseCapture="MicButton_LostMouseCapture"
                        PreviewKeyDown="MicButton_PreviewKeyDown"
                        PreviewKeyUp="MicButton_PreviewKeyUp" />

                <Button Grid.Column="3"
                        Margin="8,0,0,0"
                        Width="48"
                        Height="48"
                        Padding="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="↑"
                        FontSize="18"
                        ToolTip="Enviar"
                        Click="SendButton_Click" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
