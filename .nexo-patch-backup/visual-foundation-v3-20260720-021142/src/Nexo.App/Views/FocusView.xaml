<UserControl x:Class="Nexo.App.Views.FocusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Enfoque" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="Temporizadores y sesiones privadas en tu equipo."
                           Style="{StaticResource MutedTextStyle}" />
            </StackPanel>
            <Border Grid.Column="1"
                    Padding="8,4"
                    Background="{DynamicResource BrushAccentSoft}"
                    CornerRadius="9"
                    VerticalAlignment="Top">
                <TextBlock x:Name="TimerStateText"
                           Text="LISTO"
                           FontSize="9"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource BrushTextSecondary}" />
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource SubtleCardStyle}"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="TimerLabelText"
                           Text="Sin sesión activa"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           Foreground="{DynamicResource BrushTextSecondary}" />
                <TextBlock x:Name="RemainingTimeText"
                           Text="00:00"
                           Margin="0,5,0,7"
                           HorizontalAlignment="Center"
                           FontSize="48"
                           FontWeight="SemiBold" />
                <ProgressBar x:Name="TimerProgressBar"
                             Height="7"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Foreground="{DynamicResource BrushAccent}"
                             Background="{DynamicResource BrushBorder}" />
                <TextBlock x:Name="TimerDetailText"
                           Margin="0,8,0,0"
                           Text="Elige una duración para comenzar."
                           TextAlignment="Center"
                           Style="{StaticResource MutedTextStyle}" />
                <UniformGrid Margin="0,12,0,0" Columns="3">
                    <Button x:Name="PauseButton"
                            Content="Pausar"
                            Margin="0,0,4,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="PauseButton_Click" />
                    <Button x:Name="ResumeButton"
                            Content="Continuar"
                            Margin="2,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="ResumeButton_Click" />
                    <Button x:Name="CancelButton"
                            Content="Cancelar"
                            Margin="4,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CancelButton_Click" />
                </UniformGrid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource SubtleCardStyle}">
                <StackPanel>
                    <TextBlock Text="Hoy" Style="{StaticResource MutedTextStyle}" />
                    <TextBlock x:Name="TodaySessionsText"
                               Text="0 sesiones"
                               Margin="0,4,0,0"
                               FontSize="18"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource SubtleCardStyle}">
                <StackPanel>
                    <TextBlock Text="Tiempo enfocado" Style="{StaticResource MutedTextStyle}" />
                    <TextBlock x:Name="TodayMinutesText"
                               Text="0 min"
                               Margin="0,4,0,0"
                               FontSize="18"
                               FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Inicio rápido"
                           Margin="0,0,0,8"
                           FontWeight="SemiBold" />
                <UniformGrid Columns="2">
                    <Button Content="Enfoque · 25 min"
                            Tag="Focus:25"
                            Margin="0,0,5,5"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="PresetButton_Click" />
                    <Button Content="Enfoque · 50 min"
                            Tag="Focus:50"
                            Margin="5,0,0,5"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="PresetButton_Click" />
                    <Button Content="Descanso · 5 min"
                            Tag="Break:5"
                            Margin="0,5,5,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="PresetButton_Click" />
                    <Button Content="Descanso · 10 min"
                            Tag="Break:10"
                            Margin="5,5,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="PresetButton_Click" />
                </UniformGrid>

                <TextBlock Text="Duración personalizada"
                           Margin="0,16,0,8"
                           FontWeight="SemiBold" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="92" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CustomMinutesTextBox"
                             Text="40"
                             Style="{StaticResource CompactTextBoxStyle}"
                             ToolTip="Minutos" />
                    <Button Grid.Column="1"
                            Content="Iniciar"
                            Margin="8,0,0,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="StartCustomButton_Click" />
                </Grid>
                <TextBlock x:Name="ActionStatusText"
                           Margin="0,9,0,0"
                           Text=""
                           TextWrapping="Wrap"
                           Style="{StaticResource MutedTextStyle}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
