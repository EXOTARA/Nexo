<Window x:Class="Nexo.App.CommandPaletteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Comandos de Nexo"
        Width="700"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        PreviewKeyDown="Window_PreviewKeyDown"
        Deactivated="Window_Deactivated"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Style x:Key="PaletteIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}" />
            <Setter Property="Background" Value="#001A1D26" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface"
                                        Property="Background"
                                        Value="{DynamicResource BrushSurfaceRaised}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource BrushTextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.68" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuggestionItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemSurface"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemSurface"
                                        Property="Background"
                                        Value="#B5222633" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemSurface"
                                        Property="Background"
                                        Value="{DynamicResource BrushAccentSoft}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MotionChipStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}" />
            <Setter Property="Background" Value="{DynamicResource BrushSurfaceRaised}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="Margin" Value="0,0,7,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChipSurface"
                                Background="{TemplateBinding Background}"
                                CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipSurface" Property="Opacity" Value="0.82" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource BrushTextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChipSurface" Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Margin="24"
            Padding="11"
            BorderThickness="1"
            CornerRadius="27"
            Opacity="0"
            SnapsToDevicePixels="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FA151821" Offset="0" />
                <GradientStop Color="#F8171B25" Offset="0.68" />
                <GradientStop Color="#FA1D1928" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#72FFFFFF" Offset="0" />
                <GradientStop Color="#20FFFFFF" Offset="0.42" />
                <GradientStop Color="#42A78EFF" Offset="1" />
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="44"
                              ShadowDepth="12"
                              Opacity="0.5"
                              Color="#000000" />
        </Border.Effect>
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="PaletteScale"
                                ScaleX="0.985"
                                ScaleY="0.985" />
                <TranslateTransform x:Name="PaletteTranslate" Y="-10" />
            </TransformGroup>
        </Border.RenderTransform>
        <Border.RenderTransformOrigin>0.5,0.2</Border.RenderTransformOrigin>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="10,8"
                    Background="#7A0F1219"
                    BorderBrush="#22FFFFFF"
                    BorderThickness="1"
                    CornerRadius="19">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="43"
                            Height="43"
                            Margin="0,0,11,0"
                            VerticalAlignment="Center"
                            Background="{DynamicResource BrushAccentSoft}"
                            CornerRadius="14">
                        <TextBlock Text="✦"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource BrushAccent}"
                                   FontSize="17"
                                   FontWeight="SemiBold" />
                    </Border>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <TextBox x:Name="PromptTextBox"
                                 MinHeight="46"
                                 Padding="1,8"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource BrushTextPrimary}"
                                 CaretBrush="{DynamicResource BrushAccent}"
                                 FontSize="18"
                                 FontWeight="Normal"
                                 TextChanged="PromptTextBox_TextChanged"
                                 SelectionBrush="{DynamicResource BrushAccentSoft}" />
                        <TextBlock x:Name="PlaceholderText"
                                   Text="Escribe una acción o pregunta"
                                   Margin="2,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   FontSize="18"
                                   IsHitTestVisible="False" />
                    </Grid>

                    <Border Grid.Column="2"
                            Margin="8,0,3,0"
                            Padding="9,5"
                            VerticalAlignment="Center"
                            Background="{DynamicResource BrushSurfaceRaised}"
                            CornerRadius="9">
                        <TextBlock Text="Esc"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   FontSize="9" />
                    </Border>

                    <Button Grid.Column="3"
                            x:Name="CustomizeButton"
                            Margin="3,0,0,0"
                            Style="{StaticResource PaletteIconButtonStyle}"
                            Content="❈"
                            FontFamily="Segoe UI Symbol"
                            FontSize="14"
                            ToolTip="Movimiento y apariencia"
                            Click="CustomizeButton_Click" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    x:Name="ExpandedSurface"
                    Margin="0,9,0,0"
                    Padding="7"
                    Background="#A8141720"
                    BorderBrush="#28FFFFFF"
                    BorderThickness="1"
                    CornerRadius="19"
                    Visibility="Collapsed"
                    Opacity="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ListBox x:Name="SuggestionsList"
                             MaxHeight="310"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource SuggestionItemStyle}"
                             MouseDoubleClick="SuggestionsList_MouseDoubleClick"
                             SelectionChanged="SuggestionsList_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="34"
                                            Height="34"
                                            Background="#5A222633"
                                            CornerRadius="11">
                                        <TextBlock Text="{Binding Glyph}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource BrushAccent}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold" />
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="11,0,10,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Margin="0,2,0,0"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontSize="10"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Padding="8,4"
                                            VerticalAlignment="Center"
                                            Background="#68222633"
                                            CornerRadius="8"
                                            Visibility="{Binding ShortcutVisibility}">
                                        <TextBlock Text="{Binding ShortcutHint}"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontSize="9" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="1" Margin="11,8,11,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↑↓ elegir"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="10" />
                            <TextBlock Text="  ·  "
                                       Foreground="{DynamicResource BrushBorder}"
                                       FontSize="10" />
                            <TextBlock Text="Tab completar"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="10" />
                            <TextBlock Text="  ·  "
                                       Foreground="{DynamicResource BrushBorder}"
                                       FontSize="10" />
                            <TextBlock Text="Enter ejecutar"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="10" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock x:Name="TimingText"
                                       Margin="0,0,12,0"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="10" />
                            <TextBlock Text="Ctrl + Enter abre Nexo"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="10" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    x:Name="CustomizationSurface"
                    Margin="0,9,0,0"
                    Padding="13"
                    Background="#D01D202B"
                    BorderBrush="#30FFFFFF"
                    BorderThickness="1"
                    CornerRadius="18"
                    Visibility="Collapsed"
                    Opacity="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Movimiento"
                                       FontWeight="SemiBold"
                                       FontSize="12" />
                            <TextBlock Text="Sutil por defecto; cambia la sensación sin recargar Nexo."
                                       Margin="0,2,0,0"
                                       Style="{StaticResource MutedTextStyle}" />
                        </StackPanel>
                        <CheckBox Grid.Column="1"
                                  x:Name="ReduceMotionCheckBox"
                                  Content="Reducir movimiento"
                                  VerticalAlignment="Center"
                                  Checked="ReduceMotionCheckBox_Changed"
                                  Unchecked="ReduceMotionCheckBox_Changed" />
                    </Grid>

                    <WrapPanel Grid.Row="1" Margin="0,12,0,0">
                        <Button x:Name="FluidMotionButton"
                                Tag="Fluid"
                                Style="{StaticResource MotionChipStyle}"
                                Content="Fluido"
                                Click="MotionPresetButton_Click" />
                        <Button x:Name="SnappyMotionButton"
                                Tag="Snappy"
                                Style="{StaticResource MotionChipStyle}"
                                Content="Rápido"
                                Click="MotionPresetButton_Click" />
                        <Button x:Name="CalmMotionButton"
                                Tag="Calm"
                                Style="{StaticResource MotionChipStyle}"
                                Content="Calmo"
                                Click="MotionPresetButton_Click" />
                        <Button x:Name="NoMotionButton"
                                Tag="None"
                                Style="{StaticResource MotionChipStyle}"
                                Content="Sin movimiento"
                                Click="MotionPresetButton_Click" />
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
